{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "jsxImportSource": "astro",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    /* On retire baseUrl qui est déconseillé */
    /* On garde les paths mais avec une syntaxe plus propre */
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"]
    }
  },
  "include": [
    "src/**/*",
    ".astro/types.d.ts" 
  ],
  "exclude": ["dist", "node_modules"]
}