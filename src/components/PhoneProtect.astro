---
// src/components/PhoneProtect.astro
interface Props {
  class?: string;
  isWhatsApp?: boolean;
  onlyLink?: boolean;
  title?: string;
  ariaLabel?: string;
}

const { 
  class: className = "", 
  isWhatsApp = false, 
  onlyLink = false, 
  title = "", 
  ariaLabel = "" 
} = Astro.props;

const XOR_KEY = 84;

const encrypt = (text: string) => {
  const reversed = text.split('').reverse().join('');
  const xorred = reversed.split('').map(char => 
    String.fromCharCode(char.charCodeAt(0) ^ XOR_KEY)
  ).join('');
  
  return Buffer.from(xorred, 'binary')
    .toString('base64')
    .replace(/=/g, '')
    .replace(/\+/g, '-')
    .replace(/\//g, '_');
};

const p1 = encrypt("06 58 90");      
const p2 = encrypt("98 35");      
const w1 = encrypt("06 58 90 98 35"); 
---

<a href="#" 
   class={`phone-placeholder ${className}`}
   data-p1={isWhatsApp ? w1 : p1} 
   data-p2={isWhatsApp ? "" : p2}
   data-type={isWhatsApp ? "whatsapp" : "tel"}
   title={title}
   aria-label={ariaLabel}>
    <slot />
    <noscript>
        {onlyLink ? (
            <span style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;">
                [Numéro protégé]
            </span>
        ) : (
            <small style="font-size: 0.85em; opacity: 0.7;">[Numéro protégé]</small>
        )}
    </noscript>
</a>

<script>
    const XOR_KEY = 84;

    const revealPhones = () => {
        const placeholders = document.querySelectorAll('.phone-placeholder');
        
        placeholders.forEach(el => {
            const linkEl = el as HTMLAnchorElement;
            if (linkEl.getAttribute('data-filled') === 'true') return;

            const part1 = linkEl.getAttribute('data-p1') || "";
            const part2 = linkEl.getAttribute('data-p2') || "";
            const type = linkEl.getAttribute('data-type');
            
            if (part1) {
                try {
                    const decrypt = (encodedBase64: string) => {
                        let base64 = encodedBase64
                            .replace(/-/g, '+')
                            .replace(/_/g, '/');
                        
                        while (base64.length % 4) {
                            base64 += '=';
                        }
                        
                        const decodedBase64 = atob(base64);
                        const dexorred = decodedBase64.split('').map(char => 
                            String.fromCharCode(char.charCodeAt(0) ^ XOR_KEY)
                        ).join('');
                        return dexorred.split('').reverse().join('');
                    };

                    const s = decrypt(part1);
                    const e = (part2 && part2 !== "") ? decrypt(part2) : "";
                    const fullDisplay = e ? `${s} ${e}` : s;
                    const digits = fullDisplay.replace(/\D/g, '');

                    // 1. On nettoie le noscript
                    const noscriptChild = linkEl.querySelector('noscript');
                    if (noscriptChild) noscriptChild.remove();

                    // 2. On vérifie s'il y a un slot (texte ou icône)
                    const hasSlot = linkEl.innerHTML.trim().length > 0;

                    // 3. On injecte le numéro uniquement si le composant a été appelé vide
                    if (!hasSlot) {
                        linkEl.innerHTML = fullDisplay;
                    }
                    
                    // 4. On configure les bons liens sur la balise <a> existante
                    if (type === "whatsapp") {
                        const waNumber = digits.startsWith('0') ? '33' + digits.substring(1) : digits;
                        linkEl.href = `https://wa.me/${waNumber}`;
                        linkEl.target = "_blank";
                        linkEl.rel = "noopener noreferrer";
                    } else {
                        const telNumber = digits.startsWith('0') ? '+33' + digits.substring(1) : `+${digits}`;
                        linkEl.href = `tel:${telNumber}`;
                    }

                    linkEl.setAttribute('data-filled', 'true');
                } catch (e) {
                    console.error("Erreur PhoneProtect:", e);
                }
            }
        });
    }

    revealPhones();
    document.addEventListener('astro:page-load', revealPhones);
</script>