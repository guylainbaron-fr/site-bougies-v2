---
// src/components/EmailProtect.astro
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

const XOR_KEY = 244; 

const encrypt = (text: string) => {
  const reversed = text.split('').reverse().join('');
  const xorred = reversed.split('').map(char => 
    String.fromCharCode(char.charCodeAt(0) ^ XOR_KEY)
  ).join('');
  
  return Buffer.from(xorred, 'binary')
    .toString('base64')
    .replace(/=/g, '')
    .replace(/\+/g, '-')
    .replace(/\//g, '_');
};

const p1 = encrypt("jeanfrancoisbaron");     
const p2 = encrypt("laposte.net"); 
---

<span class={`email-placeholder ${className}`}
      data-p1={p1} 
      data-p2={p2}>
    <slot /><noscript><small style="font-size: 0.85em; opacity: 0.7;">[Email protégé]</small></noscript>
</span>

<script>
    const XOR_KEY = 244; 

    const revealEmails = () => {
        const placeholders = document.querySelectorAll('.email-placeholder');
        
        placeholders.forEach(el => {
            const htmlEl = el as HTMLElement;
            if (htmlEl.getAttribute('data-filled') === 'true') return;

            const part1 = htmlEl.getAttribute('data-p1') || "";
            const part2 = htmlEl.getAttribute('data-p2') || "";
            
            if (part1 && part2) {
                try {
                    const decrypt = (encodedBase64: string) => {
                        let base64 = encodedBase64
                            .replace(/-/g, '+')
                            .replace(/_/g, '/');
                        
                        while (base64.length % 4) {
                            base64 += '=';
                        }
                        
                        const decodedBase64 = atob(base64);
                        const dexorred = decodedBase64.split('').map(char => 
                            String.fromCharCode(char.charCodeAt(0) ^ XOR_KEY)
                        ).join('');
                        return dexorred.split('').reverse().join('');
                    };

                    const user = decrypt(part1);
                    const domain = decrypt(part2);
                    const email = `${user}@${domain}`;

                    const noscriptChild = htmlEl.querySelector('noscript');
                    if (noscriptChild) noscriptChild.remove();

                    const originalContent = htmlEl.innerHTML;
                    const hasSlot = htmlEl.innerText.trim().length > 0;
                    
                    const link = document.createElement('a');
                    link.href = `mailto:${email}`;
                    link.className = htmlEl.className.replace('email-placeholder', '').trim();
                    
                    link.innerHTML = hasSlot ? originalContent : email;
                    
                    htmlEl.setAttribute('data-filled', 'true');
                    htmlEl.replaceWith(link);
                } catch (e) {
                    console.error("Erreur EmailProtect:", e);
                }
            }
        });
    }

    revealEmails();
    document.addEventListener('astro:page-load', revealEmails);
</script>

<style>
    .email-placeholder {
        display: contents;
    }
</style>