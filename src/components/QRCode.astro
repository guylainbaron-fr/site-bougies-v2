---
// src/components/QRCode.astro
interface Props {
  url?: string;
  size?: number;
}

const siteUrl = "https://jf-aniuta.vercel.app/";
const { size = 150 } = Astro.props;

// Tes couleurs exactes (sans le # pour l'URL)
const darkColor = "4a3728"; // Marron
const lightColor = "fdfaf7"; // Beige de fond

const qrImageUrl = `https://quickchart.io/qr?text=${encodeURIComponent(siteUrl)}&size=${size}&margin=2&dark=${darkColor}&light=${lightColor}&ecLevel=H`;
---

<div class="qr-code-wrapper">
  <img 
    src={qrImageUrl} 
    alt="QR Code Artisanal"
    width={size} 
    height={size}
    loading="eager"
  />
</div>

<style>
  .qr-code-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    background: #fdfaf7; /* Assorti au fond du QR */
    padding: 8px;
    border-radius: 8px;
    /* On ajoute une petite ombre légère pour le rendu sur la carte */
    box-shadow: 0 2px 8px rgba(74, 55, 40, 0.1);
  }
  img {
    display: block;
    max-width: 100%;
    height: auto;
  }
</style>