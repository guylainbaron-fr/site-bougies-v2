---
// src/components/QRCode.astro
interface Props {
  url?: string;
  size?: number;
}

const { url = "https://jf-aniuta.vercel.app/", size = 150 } = Astro.props;

// On utilise l'API de Google Charts pour générer le QR code proprement sans bibliothèque
const qrImageUrl = `https://chart.googleapis.com/chart?cht=qr&chs=${size}x${size}&chl=${encodeURIComponent(url)}&chld=M|2`;
---

<div class="qr-code">
  <img src={qrImageUrl} alt="QR Code" width={size} height={size} />
</div>

<style>
  .qr-code img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }
</style>