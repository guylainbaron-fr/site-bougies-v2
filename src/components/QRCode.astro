---
// src/components/QRCode.astro
interface Props {
  url?: string;
  size?: number;
}

// On définit l'URL en dur ici pour être certain qu'il n'y a pas d'erreur de transmission
const siteUrl = "https://jf-aniuta.vercel.app/";
const { size = 150 } = Astro.props;

const darkColor = "4a3728"; 
const lightColor = "fdfaf7"; 

// On utilise l'API QuickChart avec un paramètre supplémentaire (center) qui aide parfois la lecture
const qrImageUrl = `https://quickchart.io/qr?text=${encodeURIComponent(siteUrl)}&size=${size}&margin=4&dark=${darkColor}&light=${lightColor}&ecLevel=H`;
---

<div class="qr-code-wrapper">
  <img 
    src={qrImageUrl} 
    alt="QR Code"
    width={size} 
    height={size}
    loading="eager"
  />
</div>

<style>
  .qr-code-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    background: #fdfaf7;
    padding: 4px;
    border-radius: 8px;
  }
  img {
    display: block;
    max-width: 100%;
    height: auto;
  }
</style>