---
import MainLayout from '../layouts/MainLayout.astro';
import { Image } from 'astro:assets';

// Importation des images pour optimisation automatique
import tarifsImg from '../assets/images/bougie-tarifs.webp';
import petiteImg from '../assets/images/bougie-petite.webp';
import moyenneImg from '../assets/images/bougie-moyenne.webp';
import grandeImg from '../assets/images/bougie-grande.webp';
import allumeesImg from '../assets/images/bougies-allumees.jpg';
---

<MainLayout 
    title="Bougie Artisanale Vanille Gourmande | Cire Végétale - J.F. & ANIUTA"
    description="Découvrez notre bougie artisanale unique, coulée à la main avec de la cire végétale et le parfum Vanille Gourmande. Commandez en ligne via WhatsApp."
    holidayMessage="De nouvelles <strong>lueurs</strong> pour une année 2026 chaleureuse."
>
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Store",
          "@id": "https://jf-aniuta.vercel.app/#store",
          "name": "Jean-François & Aniuta - Bougies Artisanales",
          "url": "https://jf-aniuta.vercel.app/bougies",
          "image": "https://jf-aniuta.vercel.app/images/logo_144.png",
          "telephone": "+33658909835",
          "priceRange": "€€",
          "description": "Découvrez nos bougies artisanales coulées à la main. Créations uniques et naturelles fabriquées dans notre atelier en Lozère.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Chasseradès",
            "postalCode": "48250",
            "addressRegion": "Occitanie",
            "addressCountry": "FR"
          },
          "hasMap": "https://maps.app.goo.gl/votre_lien_si_existant",
          "sameAs": [
            "https://www.facebook.com/profile.php?id=61550190415219&locale=fr_FR",
            "https://www.instagram.com/jean_francois_aniuta/",
            "https://www.tiktok.com/@jeanfrancoisbaron2",
            "https://wa.me/33658909835"
          ]
        },
        {
          "@type": "WebPage",
          "@id": "https://jf-aniuta.vercel.app/bougies#webpage",
          "url": "https://jf-aniuta.vercel.app/bougies",
          "name": "Les Bougies Artisanales - Jean-François & Aniuta",
          "description": "Catalogue de nos bougies artisanales parfumées. Fabrication française et artisanale en Lozère."
        }
      ]
    }
    </script>

    <section id="bougies">
        <div class="container">
            <h2>Découvrez nos Bougies Artisanales</h2>
            
            <p>
                Chaque bougie Jean François & Aniuta est une invitation à l'évasion olfactive, conçue avec la plus grande exigence. Coulées à la main dans notre atelier en Lozère, elles incarnent notre engagement envers l'artisanat de qualité, le naturel et le respect de l'environnement. Découvrez la différence d'une bougie véritablement artisanale.
            </p>

            <div class="bougies-wrapper-seo">
                <div class="tarifs-block">
                    <Image 
                        src={tarifsImg} 
                        alt="Grille des tarifs des bougies" 
                        class="tarifs-image"
                        width={565}   
                        height={800}  
                        loading="eager"     
                        fetchpriority="high"
                    />
                </div>
                
                <div class="tailles-wrapper">
                    <Image 
                        src={petiteImg} 
                        alt="Petite taille de bougie" 
                        class="taille-image"
                        width={240}   
                        height={268}  
                    />
                    <Image 
                        src={moyenneImg} 
                        alt="Taille moyenne de bougie" 
                        class="taille-image"
                        width={240}   
                        height={268}  
                    />
                    <Image 
                        src={grandeImg} 
                        alt="Grande taille de bougie" 
                        class="taille-image"
                        width={240}   
                        height={268}  
                    />
                </div>
            </div>
            
            <a href="https://wa.me/33658909835" target="_blank" class="btn large-btn whatsapp-btn main-whatsapp-btn">
                <i class="fab fa-whatsapp"></i> Commander en ligne via WhatsApp
            </a>
            
            <div class="whatsapp-image-container">
                <Image 
                    src={allumeesImg} 
                    alt="Bougies cèpes allumées" 
                    class="image-sous-whatsapp"
                    width={500}
                    height={500}
                />
            </div>
        </div>
    </section>

    <section id="conseils" style="background-color: var(--couleur-fond-clair);">
        <div class="container">
            <h2>Conseils d'Utilisation</h2>
            <p>Pour profiter au maximum de votre bougie Jean François & Aniuta, suivez cette recommandation :</p>
            
            <ul class="conseils-list">
                <li class="security-alert">
                    <span><strong>Sécurité :</strong> Ne laissez jamais une bougie allumée sans surveillance et tenez-la hors de portée des enfants et des animaux.</span>
                </li>
            </ul>
            
            <a href="/contact" class="btn">Poser une Question</a>
        </div>
    </section>
</MainLayout>