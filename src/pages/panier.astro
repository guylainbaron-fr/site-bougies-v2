---
import MainLayout from '../layouts/MainLayout.astro';
const pageId = "panier";
---

<MainLayout title="Mon Panier - Jean-François & Aniuta" pageId={pageId}>
    <style>
    /* 1. ZONE DE SÉLECTION */
    .mr-selection-wrapper {
        margin-top: 10px;
        padding-top: 18px; /* Espace de sécurité pour l'animation de survol du bouton */
        border-top: 1px dashed var(--sable-dore);
        transition: all 0.3s ease;
    }

    :global(#mr-selection-area.hidden) {
        display: none !important;
    }

    /* Style spécifique pour désécraser le bouton dans la modal */
    :global(.modal-search-group) {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        align-items: stretch;
    }
    :global(.modal-search-group .btn) {
        margin: 0 !important; /* Annule le margin: 50px auto du style.css */
        height: 48px !important;
        width: auto; /* Permet au bouton de s'adapter à son contenu */
        flex-shrink: 0;
        padding: 0 20px !important; /* Ajoute du padding pour le texte */
    }

    .selected-relay-box {
        margin-top: 10px;
        padding: 12px;
        background: var(--vanille-brume);
        border: 1.5px dashed var(--sable-dore);
        border-radius: 8px;
        font-size: 0.85rem;
        line-height: 1.4;
        text-align: center;
    }

    :global(#mr-custom-results) {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-height: 350px;
        overflow-y: auto;
        padding-right: 5px;
        margin-top: 10px;
    }

    /* STYLES GLOBAUX POUR LE JS */
    :global(.relay-card) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px;
        border: 1px solid #e0c297 !important;
        border-radius: 8px;
        background: white !important;
        cursor: pointer;
        transition: all 0.2s ease;
        text-align: left !important;
        margin-bottom: 8px;
    }
    :global(.relay-card.selected) {
        border: 2px solid var(--brun-coco) !important;
        background: var(--vanille-pure) !important;
        box-shadow: 0 4px 12px rgba(74, 55, 40, 0.1);
    }
    :global(.relay-card:hover) { border-color: var(--brun-coco); background: var(--fond-sable) !important; }
    :global(.relay-card strong) { color: var(--brun-coco) !important; display: block; margin-bottom: 4px; font-size: 0.95rem; }
    :global(.relay-card p) { 
        margin: 0 !important; font-size: 0.85rem !important; color: var(--texte-galet) !important; text-align: left !important;
        min-height: auto !important; /* Annule le min-height global */
        max-width: none !important; /* Annule le max-width du p global */
        margin-left: 0 !important; /* Annule le margin-left: auto du p global */
        margin-right: 0 !important; /* Annule le margin-right: auto du p global */
    }

    /* Bouton d'action dans la carte relais */
    :global(.relay-card .btn) {
        margin: 0 !important;
        height: auto !important;
        width: auto !important;
        padding: 8px 12px !important;
        font-size: 0.75rem !important;
    }

    :global(.relay-horaires) {
        margin-top: 12px;
        padding-top: 8px;
        border-top: 1px solid #f0f0f0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px;
        font-size: 0.75rem;
        color: var(--bois-flotte);
    }
</style>

    <section id="panier-page" style="background-color: var(--fond-ecume);">
        <div class="container">
            <div class="panier-header">
                <span class="panier-tag">Votre sélection</span>
                <h1>Mon Panier</h1>
            </div>

            <div id="cart-empty" class="hidden">
                <div class="empty-boutique-style">
                    <p>Votre panier est actuellement vide.</p>
                    <a href="/boutique" class="filter-btn active" style="text-decoration: none; display: inline-block; margin-top: 20px;">Retourner à la boutique</a>
                </div>
            </div>

            <div id="cart-content" class="panier-main-grid hidden">
                <div class="produits-panier-list" id="cart-items-list">
                    </div>

<aside class="panier-summary-sidebar">
    <div class="recap-card">
        <h3>Résumé de la commande</h3>
        
        <!-- SECTION LIVRAISON -->
        <div class="shipping-selector" style="margin-bottom: 20px; padding: 15px; background: var(--fond-sable); border-radius: 8px; border: 1px solid var(--sable-dore);">
    <strong style="display: block; font-size: 0.8rem; text-transform: uppercase; margin-bottom: 12px; color: var(--brun-coco);">Mode de livraison</strong>
    
    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; font-size: 0.9rem; margin-bottom: 8px;">
        <input type="radio" name="shipping-method" value="colissimo" checked onchange="handleShippingChange('colissimo')">
        <span>Colissimo (Domicile)</span>
    </label>
    
    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; font-size: 0.9rem;">
        <input type="radio" name="shipping-method" value="mondialrelay" onchange="handleShippingChange('mondialrelay')">
        <span>Mondial Relay</span>
    </label>

    <!-- Bouton pour ouvrir la modal -->
    <div id="mr-selection-area" class="mr-selection-wrapper hidden">
        <!-- On supprime la marge du .btn global pour un alignement précis via le padding du wrapper -->
        <style>
            #mr-selection-area .btn.filter-btn { margin: 0 !important; }
        </style>
        <button type="button" class="btn filter-btn active" onclick="openMRModal()" style="width: 100%; padding: 12px; font-size: 0.85rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg> Choisir mon point relais
        </button>
        
        <!-- Petit rappel du point sélectionné sous le bouton -->
        <div id="relay-display" class="selected-relay-box hidden">
            <span id="relay-info-text" style="color: var(--brun-coco);"></span>
        </div>
    </div>
</div>

        <!-- RÉCAPITULATIF FINANCIER -->
        <div class="recap-details">
            <div class="recap-line">
                <span>Articles (<span id="res-count">0</span>)</span>
                <span id="res-subtotal">0.00 €</span>
            </div>
            <div class="recap-line">
                <span>Poids total</span>
                <span id="res-weight">0g</span>
            </div>
            <div class="recap-line shipping-info">
                <span id="res-shipping-label">Livraison & Emballage</span>
                <span id="res-shipping">0.00 €</span>
            </div>
        </div>
        
        <div class="recap-total">
            <label>Total TTC</label>
            <span id="res-total">0.00 €</span>
        </div>

        <button id="checkout-btn" class="btn-checkout-final">
            Valider la commande
        </button>

        <a href="/boutique" class="btn-continue-shopping">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Continuer mes achats
        </a>

        <!-- TES LOGOS DE PAIEMENT PRÉSERVÉS -->
        <div class="recap-trust">
            <div class="payment-row">
                <img src="/images/paiement/visa.svg" alt="Visa" class="icon-visa">
                <img src="/images/paiement/mastercard.svg" alt="Mastercard" class="icon-master">
                <img src="/images/paiement/applepay.svg" alt="Apple Pay" class="icon-apple">
            </div>
            <div class="payment-row">
                <img src="/images/paiement/googlepay.svg" alt="Google Pay" class="icon-google">
                <div class="stripe-badge-inline">
                    <img src="/images/paiement/stripe.svg" alt="Stripe">
                </div>
            </div>
            <p class="trust-text">Paiement 100% sécurisé via Stripe</p>
        </div>
    </div>
</aside>
            </div>
        </div>
    </section>

<!-- MODAL MONDIAL RELAY -->
<div id="mr-modal" class="modal" style="display:none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); backdrop-filter: blur(3px);">
    <div class="modal-content" style="background: white; margin: 10vh auto; padding: 25px; border-radius: 12px; max-width: 500px; width: 90%; position: relative; box-shadow: 0 10px 30px rgba(0,0,0,0.3); text-align: center;">
        <span onclick="closeMRModal()" style="position: absolute; right: 20px; top: 15px; cursor: pointer; font-size: 24px; color: #999;">&times;</span>
        
        <h3 style="margin-bottom: 20px; color: var(--brun-coco);">Choisir un Point Relais</h3>
        
        <div class="modal-search-group">
            <input type="text" id="modal-zip-input" placeholder="Code Postal (ex: 48800)"
                   inputmode="numeric" 
                   pattern="[0-9]*" 
                   maxlength="5"
                   oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                   style="flex: 1; padding: 12px; border: 1px solid var(--sable-dore); border-radius: 6px; font-weight: 400;">
            <button onclick="fetchRelays()" class="btn filter-btn active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <span>Rechercher</span>
            </button>
        </div>

        <div id="mr-custom-results"></div>
    </div>
</div>

    <div id="toast-container" class="toast-container"></div>
</MainLayout>

<script is:inline>
    /**
     * --- GESTION DES NOTIFICATIONS (TOASTS) ---
     */
    function showToast(message, type = 'info') {
        const container = document.getElementById('toast-container');
        if (!container) return;
        
        const toast = document.createElement('div');
        toast.className = 'toast-message';
        const icon = type === 'delete' ? '✕' : '✓';
        toast.innerHTML = `<span>${icon}</span> ${message}`;
        
        container.appendChild(toast);

        setTimeout(() => {
            toast.classList.add('fade-out');
            setTimeout(() => toast.remove(), 400);
        }, 2500);
    }

    // État global du mode de livraison
    let currentShippingMethod = 'colissimo';
    let selectedRelay = null;
    let cartPoidsTotal = 0; 

/**
     * --- UTILITAIRES DE CALCUL ---
     */
    function parseWeight(weightInput) {
        if (typeof weightInput === 'number') return weightInput;
        if (!weightInput) return 0;
        const cleaned = weightInput.toString().replace(/[^\d.]/g, '');
        return parseFloat(cleaned) || 0;
    }

    function calculFraisPort(weight, method = 'colissimo') {
        // On ajoute 200g de sécurité (emballage artisanal robuste)
        const totalWeight = weight > 0 ? weight + 300 : 0;

        if (totalWeight <= 0)     return 0;

        // Tarifs Mondial Relay (Exemple 2024 France)
        if (method === 'mondialrelay') {
        if (totalWeight <= 500)   return 4.90;
        if (totalWeight <= 1000)  return 5.50; 
        if (totalWeight <= 2000)  return 7.20; 
        if (totalWeight <= 3000)  return 8.50; 
        if (totalWeight <= 5000)  return 11.90;
        if (totalWeight <= 7000)  return 14.50;
        if (totalWeight <= 10000) return 16.50;
        return -1;
    }
        
        // Paliers petits poids
        if (totalWeight <= 250)   return 6.00;
        if (totalWeight <= 500)   return 8.00;
        if (totalWeight <= 750)   return 9.50;
        if (totalWeight <= 1000)  return 10.00;
        
        // Paliers moyens poids (resserrés)
        if (totalWeight <= 2000)  return 11.50;
        if (totalWeight <= 3000)  return 14.50; // Nouveau palier
        if (totalWeight <= 4000)  return 16.50; // Nouveau palier
        if (totalWeight <= 5000)  return 18.00;
        
        // Paliers lourds (sécurisés)
        if (totalWeight <= 7000)  return 22.50;
        if (totalWeight <= 8500)  return 24.50; // Nouveau palier
        if (totalWeight <= 10000) return 26.50; // Arrondi sup pour 10kg
        
        return -1; // Trop lourd (> 10kg emballé)
    }

    window.handleShippingChange = (method) => {
    currentShippingMethod = method;
    const mrArea = document.getElementById('mr-selection-area');
    const relayDisplay = document.getElementById('relay-display');
    const infoText = document.getElementById('relay-info-text');

    if (mrArea) {
        mrArea.classList.toggle('hidden', method !== 'mondialrelay');
        if (method !== 'mondialrelay') {
            selectedRelay = null;
            relayDisplay?.classList.add('hidden');
            if (infoText) infoText.innerHTML = '';
        }
    }
    renderPanier();
};

window.openMRModal = () => {
    const modal = document.getElementById('mr-modal');
    if (modal) modal.style.display = 'block';
};

window.closeMRModal = () => {
    const modal = document.getElementById('mr-modal');
    if (modal) modal.style.display = 'none';
};

    window.fetchRelays = async () => {
    const cpInput = document.getElementById('modal-zip-input');
    const cp = cpInput?.value.trim();
    const resultsDiv = document.getElementById('mr-custom-results');

    if (!resultsDiv) return;

    if (!cp || cp.length !== 5) {
        showToast("Code postal invalide (5 chiffres)", "delete");
        return;
    }

    resultsDiv.innerHTML = '<p style="font-size:0.8rem; text-align:center; padding:10px;">Recherche...</p>';
    
    try {
        const response = await fetch(`/api/mondial-relay?cp=${cp}&poids=${cartPoidsTotal}`);
        const data = await response.json();

        if (!data.points || data.points.length === 0) {
            resultsDiv.innerHTML = '<p style="font-size:0.8rem; text-align:center;">Aucun point trouvé.</p>';
            return;
        }

        resultsDiv.innerHTML = "";
        data.points.forEach(point => {
            const card = document.createElement('div');
            card.className = 'relay-card';

            const horairesHtml = (point.horaires && point.horaires.length > 0) 
    ? `<div class="relay-horaires">
        ${point.horaires.map(h => `<span>${h}</span>`).join('')}
       </div>`
    : '';

            card.innerHTML = `
                <div style="flex: 1; text-align: left; padding-right: 15px;">
                    <strong>${point.nom}</strong>
                    <p>${point.adresse}</p>
                    <p style="color: var(--bois-flotte); font-size: 0.8rem;">${point.cp} ${point.ville}</p>
                    ${horairesHtml}
                </div>
                <div style="display: flex; align-items: center; justify-content: center; width: 40px; flex-shrink: 0;">
                    <div class="relay-check-icon" style="opacity: 0; color: var(--brun-coco); line-height: 0; transition: opacity 0.3s ease;">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    </div>
                </div>
            `;
            card.onclick = (e) => {
                // 1. Toujours mettre à jour la sélection visuelle et les données au clic sur la carte
                resultsDiv.querySelectorAll('.relay-card').forEach(c => {
                    c.classList.remove('selected');
                    const icon = c.querySelector('.relay-check-icon');
                    if (icon) icon.style.opacity = '0';
                });
                card.classList.add('selected');
                const icon = card.querySelector('.relay-check-icon');
                if (icon) icon.style.opacity = '1';

                selectedRelay = { 
                    id: point.id, 
                    name: point.nom, 
                    address: `${point.adresse}, ${point.cp} ${point.ville}` 
                };
                const infoText = document.getElementById('relay-info-text');
                const relayDisplay = document.getElementById('relay-display');

                if (infoText) infoText.innerHTML = `<strong>${point.nom}</strong><br>${point.adresse}`;
                relayDisplay?.classList.remove('hidden');
                
                // 2. Fermeture automatique après 2 secondes pour laisser le temps de voir la coche
                showToast("Point sélectionné");
                
                setTimeout(() => {
                    closeMRModal();
                }, 2000);
            };
            resultsDiv.appendChild(card);
        });
    } catch (e) {
        resultsDiv.innerHTML = '<p style="color:red; font-size:0.8rem; text-align:center;">Erreur de recherche</p>';
    }
};

    /**
     * --- NETTOYAGE AUTOMATIQUE DU PANIER ---
     * Compare le local avec la BD Upstash et vire les surplus
     */
    async function syncStocks() {
        try {
            // On interroge ton API (qui est sécurisée par le .env côté serveur)
            const response = await fetch('/api/produits');
            if (!response.ok) return;
            
            const produitsBD = await response.json();
            let cart = JSON.parse(localStorage.getItem('panier-atelier')) || [];
            const avantModif = JSON.stringify(cart);

            // Filtrage : on ne garde que ce qui est en stock réel
            const panierFiltre = cart.filter(item => {
                const live = produitsBD.find(p => p.id === item.id);
                
                // 1. Si plus en BD ou stock à 0 -> On supprime l'article du panier
                if (!live || live.stock <= 0) return false;

                // 2. Si le client en a 8 mais que la BD dit 1 -> On redescend à 1
                if (item.quantite > live.stock) {
                    item.quantite = live.stock;
                }

                // 3. Mise à jour des métadonnées (prix/poids)
                item.stock = live.stock;
                item.prix = live.prix;
                return true;
            });

            // Sauvegarde seulement si le panier a été modifié
            if (JSON.stringify(panierFiltre) !== avantModif) {
                localStorage.setItem('panier-atelier', JSON.stringify(panierFiltre));
                
                // Rafraîchissement du design
                renderPanier(); 
                
                // Notification pour le reste du site
                window.dispatchEvent(new Event('storage'));
                showToast("Panier actualisé selon les stocks réels", "delete");
            }
        } catch (error) {
            console.error("Erreur de synchronisation stocks");
        }
    }

    /**
     * --- RENDU DU PANIER ---
     */
    function renderPanier() {
        const cart = JSON.parse(localStorage.getItem('panier-atelier')) || [];
        const emptyDiv = document.getElementById('cart-empty');
        const contentDiv = document.getElementById('cart-content');
        const listDiv = document.getElementById('cart-items-list');

        if (!cart.length) {
            if(emptyDiv) emptyDiv.classList.remove('hidden');
            if(contentDiv) contentDiv.classList.add('hidden');
            return;
        }

        if(emptyDiv) emptyDiv.classList.add('hidden');
        if(contentDiv) contentDiv.classList.remove('hidden');
        if(!listDiv) return;

        listDiv.innerHTML = '';
        let totalCommande = 0;
        let poidsTotal = 0;
        let nombreArticles = 0;
        cartPoidsTotal = 0;

        // Calcul initial pour le poids total
        cart.forEach(item => {
            const w = parseWeight(item.poids);
            poidsTotal += (w * item.quantite);
            totalCommande += (item.prix * item.quantite);
            nombreArticles += item.quantite;
        });
        cartPoidsTotal = poidsTotal;

        // Génération des lignes
        cart.forEach((item, index) => {
            const unitW = parseWeight(item.poids);
            const linePrice = item.prix * item.quantite;
            
            // Sécurité anti-spam : on bloque si stock atteint OU si +1 dépasse 10kg
            const isStockMax = item.stock !== undefined && item.quantite >= item.stock;
            const isPoidsMax = (poidsTotal + unitW) > 10000;
            const canNotAdd = isStockMax || isPoidsMax;

            listDiv.innerHTML += `
                <div class="panier-item-card">
                    <div class="p-img-container">
                        <img src="${item.image}" alt="${item.nom}" onerror="this.src='/images/logo-entreprise.webp'">
                    </div>
                    <div class="p-info">
                        <h4>${item.nom}</h4>
                        <span class="p-meta">${item.poids}g — ${item.prix.toFixed(2)}€/unité</span>
                    </div>
                    <div class="p-actions">
                        <div class="p-qty-selector">
                            <button onclick="updateQty(${index}, -1)">−</button>
                            <span class="qty-num">${item.quantite}</span>
                            <button 
                                onclick="updateQty(${index}, 1)" 
                                ${canNotAdd ? 'disabled style="opacity:0.2; cursor:not-allowed;"' : ''}
                                title="${isPoidsMax ? 'Limite de 10kg atteinte' : ''}"
                            >+</button>
                        </div>
                        <div class="p-total-line">${linePrice.toFixed(2)}€</div>
                        <button class="p-remove" onclick="deleteItem(${index})">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18m-2 0v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6m3 0V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                        </button>
                    </div>
                </div>
            `;
        });

        // Récapitulatif
        cartPoidsTotal = poidsTotal;
        const fraisPort = calculFraisPort(cartPoidsTotal, currentShippingMethod);
        const shippingElem = document.getElementById('res-shipping');
        const shippingLabelElem = document.getElementById('res-shipping-label');
        const totalElem = document.getElementById('res-total');
        const payBtn = document.getElementById('checkout-btn');

        const methodLabel = currentShippingMethod === 'mondialrelay' ? 'Livraison Mondial Relay' : 'Livraison Colissimo';

        if (fraisPort === -1) {
            if (shippingElem) shippingElem.textContent = "Sur devis";
            if (shippingLabelElem) shippingLabelElem.textContent = "Livraison";
            if (totalElem) totalElem.textContent = "— €";
            if (payBtn) {
                payBtn.disabled = true;
                payBtn.textContent = "Poids excessif (> 10kg)";
            }
        } else {
            const finalTotal = totalCommande + fraisPort;
            if (shippingElem) shippingElem.textContent = fraisPort.toFixed(2) + " €";
            if (shippingLabelElem) shippingLabelElem.textContent = methodLabel;
            if (totalElem) totalElem.textContent = finalTotal.toFixed(2) + " €";
            if (payBtn) {
                payBtn.disabled = false;
                payBtn.textContent = "Valider la commande";
            }
        }

        if(document.getElementById('res-count')) document.getElementById('res-count').textContent = nombreArticles;
        if(document.getElementById('res-weight')) document.getElementById('res-weight').textContent = poidsTotal + 'g';
        if(document.getElementById('res-subtotal')) document.getElementById('res-subtotal').textContent = totalCommande.toFixed(2) + ' €';
    }

    /**
     * --- ACTIONS ---
     */
    window.updateQty = (idx, delta) => {
        let cart = JSON.parse(localStorage.getItem('panier-atelier'));
        const item = cart[idx];
        const unitW = parseWeight(item.poids);
        const currentPoids = cart.reduce((acc, it) => acc + (parseWeight(it.poids) * it.quantite), 0);

        if (delta > 0) {
            if (item.stock !== undefined && (item.quantite + delta) > item.stock) {
                showToast("Désolé, stock épuisé", "delete");
                return;
            }
            if ((currentPoids + unitW) > 10000) {
                showToast("Limite de 10kg atteinte", "delete");
                return;
            }
        }

        item.quantite += delta;
        if (item.quantite < 1) return deleteItem(idx);

        localStorage.setItem('panier-atelier', JSON.stringify(cart));
        renderPanier();
        window.dispatchEvent(new Event('storage'));
    };

    window.deleteItem = (idx) => {
        let cart = JSON.parse(localStorage.getItem('panier-atelier'));
        cart.splice(idx, 1);
        localStorage.setItem('panier-atelier', JSON.stringify(cart));
        renderPanier();
        window.dispatchEvent(new Event('storage'));
        showToast("Article retiré", "delete");
    };

    function initCheckout() {
        const payBtn = document.getElementById('checkout-btn');
        if (!payBtn) return;
        payBtn.onclick = async () => {
            const cart = JSON.parse(localStorage.getItem('panier-atelier')) || [];
            if (!cart.length) return;

            // À l'intérieur de payBtn.onclick, avant le fetch :
            if (currentShippingMethod === 'mondialrelay' && !selectedRelay) {
            showToast("Sélectionnez un point relais", "delete");
            document.getElementById('mr-zip-input')?.focus();
            return;
        }

            payBtn.disabled = true;
            payBtn.textContent = "Lien avec Stripe...";
            // Optionnel: ajouter une icône de chargement
            // payBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Lien avec Stripe...';
            try {
                // Appel de la nouvelle API pour créer une session Stripe Checkout
                const response = await fetch('/api/create-checkout-session', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                    cartItems: cart,
                    shippingMethod: currentShippingMethod,
                    relayData: selectedRelay, 
                    shippingFee: calculFraisPort(cartPoidsTotal, currentShippingMethod) // Utilise cartPoidsTotal
                    })
                });
                const data = await response.json();
                if (response.ok && data.url) {
                    window.location.href = data.url; // Rediriger vers Stripe Checkout
                } else {
                    throw new Error(data.error || "Erreur inconnue lors de la création de la session.");
                }
            } catch (err) {
                console.error("Erreur de paiement:", err);
                showToast(err.message || "Erreur lors de la création de la session de paiement.", "delete");
                payBtn.disabled = false;
                payBtn.textContent = "Valider la commande";
            }
        };
    }

    async function initPage() {
        await syncStocks(); // On vérifie les stocks réels AVANT d'afficher
        renderPanier();
        initCheckout();
    }

    document.addEventListener('astro:page-load', initPage);
    if (document.readyState === 'complete') initPage();
    else window.addEventListener('DOMContentLoaded', initPage);
</script>