---
// REMPLACEMENT DES IMPORTS
import MainLayout from '../layouts/MainLayout.astro';
import { kv } from '../lib/kv'; // On appelle la base de données
import PhoneProtect from '../components/PhoneProtect.astro';

// FORCE LE MODE DYNAMIQUE (indispensable pour Vercel/KV)
export const prerender = false;

const pageId = "boutique";
const categories = ["Bougies", "Sculptures", "Tableaux", "Accessoires", "Tous"];

// RÉCUPÉRATION DES DONNÉES
const data = await kv.get("boutique:produits");
const produits = (Array.isArray(data) ? data : [])
    .filter(p => {
        if (!p || !p.id) return false; // Filtre de base
        // Si le produit est une pièce unique et que le stock est à 0, on ne l'affiche plus.
        if (p.isUnique && p.stock <= 0) {
            return false;
        }
        return true;
    })
    .sort((a, b) => (Number(a.ordre) || 0) - (Number(b.ordre) || 0))
    .map(p => ({
        ...p,
        // On injecte l'optimisation Cloudinary (f_auto: format, q_auto: qualité)
        image: p.image?.includes('cloudinary.com') ? p.image.replace('upload/', 'upload/f_auto,q_auto,w_800/') : p.image,
        image2: p.image2?.includes('cloudinary.com') ? p.image2.replace('upload/', 'upload/f_auto,q_auto,w_400/') : p.image2,
        image3: p.image3?.includes('cloudinary.com') ? p.image3.replace('upload/', 'upload/f_auto,q_auto,w_400/') : p.image3
    }));

// Récupération de la catégorie active depuis l'URL (pour le rendu serveur)
const activeCat = Astro.url.searchParams.get('cat') || "Bougies";
const activePage = parseInt(Astro.url.searchParams.get('page') || "1") || 1;

let canonicalPath = "/boutique";
const searchParams = new URLSearchParams();

if (activeCat !== 'Bougies') searchParams.set('cat', activeCat);
if (activePage > 1) searchParams.set('page', activePage.toString());

const queryString = searchParams.toString();
if (queryString) {
    canonicalPath += `?${queryString}`;
}
---

<MainLayout title="Boutique Artisanale - Jean-François & Aniuta" pageId={pageId} canonical={canonicalPath}>
    <style>
        /* Style spécifique pour les miniatures d'images */
        .thumbnails-gallery {
            display: flex;
            gap: 10px;
            justify-content: center;
            padding: 15px;
            background: #fff;
            border-bottom: 1px solid var(--fond-sable);
        }
        .thumb-img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            cursor: pointer;
            border-radius: 6px;
            border: 1.5px solid var(--sable-dore);
            transition: all 0.2s ease;
        }
        .thumb-img:hover { transform: scale(1.1); border-color: var(--brun-coco); }

        /* Style spécifique pour le bouton de partage */
        .produit-card .image-container { position: relative; }
        
        .btn-share {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid var(--sable-dore);
            border-radius: 50%;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 10;
            box-shadow: 0 4px 8px rgba(45, 34, 26, 0.1);
        }
        .btn-share:hover {
            background: var(--vanille-pure);
            border-color: var(--brun-coco);
            transform: scale(1.1);
        }
        .btn-share img { width: 18px; height: 18px; }

        /* Highlight pour le produit ciblé par l'ancre */
        .produit-card { transition: border 0.6s ease, box-shadow 0.6s ease; border: 2px solid transparent; }
        .produit-card.is-highlighted {
            border: 2px solid var(--vanille-eclat);
            box-shadow: 0 0 25px rgba(233, 196, 106, 0.4);
        }

        /* Style bouton WhatsApp "Sur demande" */
        .btn-sur-demande {
            background-color: var(--sable-dore) !important;
            color: var(--brun-profond) !important;
            border: 1px dashed var(--brun-coco) !important;
            font-size: 0.75rem !important;
            text-decoration: none !important;
            margin: 0 !important;
        }
    </style>
<script type="application/ld+json" slot="head">
