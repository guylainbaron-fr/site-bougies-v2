</script>

    <section id="boutique-liste" style="background-color: var(--fond-ecume);">
        <div class="container">
            <h2>Boutique de l'Atelier</h2>
            <p>
                Retrouvez nos créations artisanales : <strong>bougies sculptées</strong>, 
                <strong>champignons réalistes parfumés</strong> à la vanille gourmande, et nos 
                <strong>accessoires artisanaux</strong>, tous façonnés à la main dans notre 
                <strong>atelier à Chasseradès en Lozère</strong>.
            </p>
            <div class="etiquette-signature">
                <p>
                    <strong>Note :</strong> Les exemplaires reçus peuvent varier légèrement en forme ou en teinte par rapport aux photos, 
                    garantissant l'authenticité d'un travail manuel sur une matière vivante.
                </p>
            </div>

<div class="filter-bar">
    {categories.map(cat => (
        <a 
            href={cat === "Bougies" ? "/boutique" : `/boutique?cat=${encodeURIComponent(cat)}`}
            class={`filter-btn ${cat === activeCat ? "active" : ""}`}
            data-category={cat}
        >
            {cat}
        </a>
    ))}
</div>
            
            <div class="produits-grid" id="grid-boutique">
                {produits.map((produit) => (
                    <div 
                        class="produit-card" 
                        data-category={produit.categorie}
                        id={produit.id}
                        style={(activeCat !== 'Tous' && produit.categorie !== activeCat) ? "display: none;" : ""}
                    >
                        <div class="image-container" style={produit.stock <= 0 ? "filter: grayscale(0.8); opacity: 0.6;" : ""}>
                            <img src={produit.image} alt={produit.nom} class="produit-img" id={`main-img-${produit.id}`} loading="lazy" />
                            <button 
                                class="btn-share" 
                                onclick={`shareProduct('${produit.id}', ${JSON.stringify(produit.nom)}, '${produit.categorie}')`}
                                title="Partager ce produit"
                            >
                                <img src="/images/share-icon.svg" alt="Partager" />
                            </button>
                        </div>
                        
                        {(produit.image2 || produit.image3) && (
                            <div class="thumbnails-gallery">
                                <img src={produit.image} class="thumb-img" onclick={`document.getElementById('main-img-${produit.id}').src='${produit.image}'`} alt="Miniature 1" />
                                {produit.image2 && <img src={produit.image2} class="thumb-img" onclick={`document.getElementById('main-img-${produit.id}').src='${produit.image2}'`} alt="Miniature 2" />}
                                {produit.image3 && <img src={produit.image3} class="thumb-img" onclick={`document.getElementById('main-img-${produit.id}').src='${produit.image3}'`} alt="Miniature 3" />}
                            </div>
                        )}

                        <div class="produit-info">
                            <h3>{produit.nom}</h3>
                            <p class="poids">{produit.poids} - {produit.parfum}</p>
                            <p class="produit-description">{produit.description}</p>
                            <div class="prix-action">
                                <span class="prix">{Number(produit.prix).toFixed(2)} €</span>
                                {produit.enMagasinUniquement ? (
                                    <PhoneProtect 
                                        isWhatsApp={true}
                                        onlyLink={true}
                                        class="btn btn-sur-demande"
                                    >
                                        Disponible sur demande
                                    </PhoneProtect>
                                ) : produit.stock > 0 ? (
                                    <button 
                                        class="btn add-to-cart" 
                                        data-id={produit.id}
                                        data-nom={produit.nom}
                                        data-prix={produit.prix}
                                        data-poids={produit.poids}
                                        data-image={produit.image}
                                        data-stock={produit.stock || 0} 
                                    >
                                        Ajouter au panier
                                    </button>
                                ) : (
                                    <button class="btn" style="background-color: var(--bois-flotte); border: none; cursor: not-allowed; opacity: 0.7;" disabled>Revient bientôt</button>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            <div class="pagination" id="pagination-boutique">
                </div>
        </div>
    </section>
    <div id="toast-container" class="toast-container"></div>
</MainLayout>
<script is:inline>
  /**
   * --- UTILITAIRES GLOBAUX ---
   */
  window.showToast = function(message, isError = false) {
    const container = document.getElementById('toast-container');
    if (!container) return;
    const toast = document.createElement('div');
    toast.className = 'toast-message';
    toast.innerHTML = `<span>${isError ? '✕' : '✓'}</span> ${message}`;
    if (isError) toast.style.borderLeft = "4px solid #e74c3c";
    container.appendChild(toast);

    setTimeout(() => {
      toast.classList.add('fade-out');
      setTimeout(() => toast.remove(), 400);
    }, 3000);
  };

  window.shareProduct = async (id, nom, cat) => {
    // 1. Construction de l'URL propre (Lien + Catégorie + Ancre)
    const url = new URL(window.location.origin + "/boutique");
    if (cat && cat !== 'Bougies' && cat !== 'Tous') {
        url.searchParams.set('cat', cat);
    }
    url.hash = id;
    const shareUrl = url.toString();

    // 2. Partage Natif (Mobile) : Plus direct, pas de main sur le message
    if (navigator.share) {
      try {
        await navigator.share({
          title: `Atelier JF & Aniuta - ${nom}`,
          text: `Découvrez cette création : ${nom} — Jean-François & Aniuta`,
          url: shareUrl
        });
      } catch (err) {
        if (err.name !== 'AbortError') window.showToast("Erreur de partage", true);
      }
    } else {
      // Fallback Desktop : Copie directe pour partage manuel
      try {
        await navigator.clipboard.writeText(shareUrl);
        window.showToast("Lien copié dans le presse-papier !");
      } catch (err) {
        window.showToast("Impossible de copier le lien.", true);
      }
    }
  };

  /**
   * --- CONFIGURATION & INITIALISATION ---
   */
  function setupBoutique() {
    initFiltresEtPagination();
    initGestionPanier();
    updateCartCount();
  }

  window.addEventListener('DOMContentLoaded', setupBoutique);
  document.addEventListener('astro:after-swap', setupBoutique);
  
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setupBoutique();
  }

  /**
   * --- BLOC 1 : FILTRES ET PAGINATION ---
   */
  function initFiltresEtPagination() {
    const itemsPerPage = 6;
    let hasScrolledToHash = false;
    
    const urlParams = new URLSearchParams(window.location.search);
    let currentFilter = urlParams.get('cat') || "Bougies";
    let currentPage = parseInt(urlParams.get('page') || "1") || 1;

    const grid = document.getElementById('grid-boutique');
    const paginationContainer = document.getElementById('pagination-boutique');
    const filterBtns = document.querySelectorAll('.filter-btn');
    
    if (!grid) return;
    const cards = Array.from(grid.getElementsByClassName('produit-card'));

    // GESTION DE L'ANCRE : Trouver la page du produit ciblé
    if (window.location.hash) {
      const targetId = window.location.hash.substring(1);
      const targetCard = cards.find(c => c.id === targetId);
      if (targetCard) {
        currentFilter = targetCard.getAttribute('data-category');
        const filteredForCalc = cards.filter(c => {
            const cat = c.getAttribute('data-category');
            return currentFilter === "Tous" || cat === currentFilter;
        });
        const idx = filteredForCalc.indexOf(targetCard);
        if (idx !== -1) currentPage = Math.floor(idx / itemsPerPage) + 1;

        filterBtns.forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-category') === currentFilter);
        });
      }
    }

    function updateDisplay() {
      const filteredCards = cards.filter(card => {
        const cat = card.getAttribute('data-category').toLowerCase().trim();
        const filter = currentFilter.toLowerCase().trim();
        return filter === "tous" || cat === filter;
      });

      // Nettoyer les surbrillances de partage (ancre)
      cards.forEach(card => card.classList.remove('is-highlighted'));

      const oldMsg = document.getElementById('empty-msg');
      if (oldMsg) oldMsg.remove();

      if (filteredCards.length === 0) {
        cards.forEach(card => card.style.display = 'none');
        // ... (message d'erreur si vide conservé)
        if (paginationContainer) paginationContainer.innerHTML = '';
        return;
      }

      const totalPages = Math.ceil(filteredCards.length / itemsPerPage);
      cards.forEach(card => card.style.display = 'none');

      const start = (currentPage - 1) * itemsPerPage;
      const end = start + itemsPerPage;
      const cardsToShow = filteredCards.slice(start, end);

      cardsToShow.forEach(card => {
        card.style.display = 'flex';
      });

      renderPagination(totalPages);

      const url = new URL(window.location.href);
      if (currentFilter === "Bougies") url.searchParams.delete('cat');
      else url.searchParams.set('cat', currentFilter);
      if (currentPage === 1) url.searchParams.delete('page');
      else url.searchParams.set('page', currentPage.toString());

      // On construit l'URL de base sans l'ancre
      const baseUrl = url.origin + url.pathname + url.search;
      // On ne préserve l'ancre que si on n'a pas encore défilé vers elle
      window.history.replaceState({}, '', hasScrolledToHash ? baseUrl : baseUrl + url.hash);

      if (!hasScrolledToHash && window.location.hash) {
        const target = document.querySelector(window.location.hash);
        if (target && target.style.display !== 'none') {
          hasScrolledToHash = true;
          target.classList.add('is-highlighted'); // Activer la surbrillance manuelle
          setTimeout(() => {
            target.scrollIntoView({ behavior: 'smooth', block: 'center' });
            
            // On retire le surlignage et l'ancre de l'URL après 4 secondes
            setTimeout(() => {
              window.history.replaceState({}, '', baseUrl);
              target.classList.remove('is-highlighted');
            }, 4000);
          }, 300);
        }
      }
    }

    function renderPagination(totalPages) {
      if (!paginationContainer) return;
      paginationContainer.innerHTML = '';
      if (totalPages <= 1) return;

      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.textContent = i;
        if (i === currentPage) btn.classList.add('active');
        btn.onclick = (e) => {
          e.preventDefault();
          hasScrolledToHash = true; // L'utilisateur navigue, on oublie l'ancre
          currentPage = i;
          updateDisplay();
          const sectionTitle = document.querySelector('#boutique-liste h2');
          if (sectionTitle) sectionTitle.scrollIntoView({ behavior: 'smooth', block: 'start' });
        };
        paginationContainer.appendChild(btn);
      }
    }

    filterBtns.forEach(btn => {
      btn.onclick = function(e) {
        e.preventDefault();
        // Redirige vers la bonne URL de catégorie, ce qui relancera le script
        // avec les bons paramètres. C'est la méthode la plus propre.
        window.location.href = this.href;
      };
    });

    updateDisplay();
  }

  function initGestionPanier() {
    const addBtns = document.querySelectorAll('.add-to-cart');
    addBtns.forEach(btn => {
      btn.onclick = function(e) {
        e.preventDefault();
        const id = this.getAttribute('data-id');
        const nom = this.getAttribute('data-nom');
        const prix = parseFloat(this.getAttribute('data-prix'));
        const image = this.getAttribute('data-image');
        const stockMax = parseInt(this.getAttribute('data-stock')) || 1;
        const poidsRaw = this.getAttribute('data-poids') || "0";
        const poidsUnitaire = parseInt(poidsRaw.replace(/[^\d]/g, '')) || 0;

        let panier = JSON.parse(localStorage.getItem('panier-atelier')) || [];
        const poidsTotalActuel = panier.reduce((acc, item) => acc + (item.poids * item.quantite), 0);
        const idx = panier.findIndex(item => item.id === id);
        const qte = idx !== -1 ? panier[idx].quantite : 0;

        if (qte + 1 > stockMax) {
          window.showToast(`Stock épuisé pour ${nom}`, true);
          return;
        }
        if (poidsTotalActuel + poidsUnitaire > 10000) {
          window.showToast(`Limite de 10kg atteinte`, true);
          return;
        }

        if (idx !== -1) panier[idx].quantite += 1;
        else panier.push({ id, nom, prix, image, poids: poidsUnitaire, quantite: 1, stock: stockMax });

        localStorage.setItem('panier-atelier', JSON.stringify(panier));
        window.dispatchEvent(new Event('storage'));
        updateCartCount();
        window.showToast(`${nom} ajouté au panier`);
      };
    });
  }

  function updateCartCount() {
    const panier = JSON.parse(localStorage.getItem('panier-atelier')) || [];
    const totalItems = panier.reduce((acc, item) => acc + item.quantite, 0);
    const badge = document.getElementById('cart-count');
    if (badge) {
      badge.textContent = totalItems;
      badge.style.display = totalItems > 0 ? 'flex' : 'none';
    }
  }
</script>