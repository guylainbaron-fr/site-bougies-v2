---
import MainLayout from '../layouts/MainLayout.astro';
const pageId = "panier-cancel";
---

<MainLayout title="Paiement Annulé - Jean-François & Aniuta" pageId={pageId}>
    
    <script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://jf-aniuta.vercel.app/#organization",
      "name": "Jean-François & Aniuta",
      "url": "https://jf-aniuta.vercel.app/",
      "logo": {
        "@type": "ImageObject",
        "@id": "https://jf-aniuta.vercel.app/#logo",
        "url": "https://jf-aniuta.vercel.app/images/logo_512.png",
        "contentUrl": "https://jf-aniuta.vercel.app/images/logo_512.png",
        "width": 512,
        "height": 512
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "149 Route du Pont du Vallat, Chasseradès",
        "addressLocality": "Mont Lozère et Goulet",
        "postalCode": "48250",
        "addressRegion": "Occitanie",
        "addressCountry": "FR"
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61550190415219&locale=fr_FR",
        "https://www.instagram.com/jean_francois_aniuta/",
        "https://www.tiktok.com/@jeanfrancoisbaron2"
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://jf-aniuta.vercel.app/panier-cancel#webpage",
      "url": "https://jf-aniuta.vercel.app/panier-cancel",
      "name": "Paiement Annulé - Jean-François & Aniuta",
      "description": "Votre processus de commande a été interrompu. Votre panier reste disponible pour finaliser vos achats ultérieurement.",
      "isPartOf": { "@id": "https://jf-aniuta.vercel.app/#website" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Accueil",
            "item": "https://jf-aniuta.vercel.app/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Panier",
            "item": "https://jf-aniuta.vercel.app/panier"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Annulation",
            "item": "https://jf-aniuta.vercel.app/panier-cancel"
          }
        ]
      }
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://jf-aniuta.vercel.app/#localbusiness",
      "name": "Jean-François & Aniuta",
      "image": "https://jf-aniuta.vercel.app/images/logo_512.png",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "149 Route du Pont du Vallat, Chasseradès",
        "addressLocality": "Mont Lozère et Goulet",
        "postalCode": "48250",
        "addressCountry": "FR"
      },
      "parentOrganization": { "@id": "https://jf-aniuta.vercel.app/#organization" }
    }
  ]
}
</script>

    <section id="panier-cancel-page" style="background-color: var(--fond-ecume); padding: 80px 0;">
        <div class="container">
            <div class="panier-header">
                <span class="panier-tag">Oups, quelque chose s'est mal passé</span>
                <h1>Paiement annulé</h1>
            </div>

            <div class="empty-boutique-style" style="max-width: 700px; margin: 40px auto;">
                <p style="font-size: 1.15rem; line-height: 1.8; margin-bottom: 30px;">
                    Votre commande n'a pas pu être finalisée. Cela peut être dû à une annulation de votre part ou à un problème technique.
                </p>
                <p style="font-size: 1rem; color: var(--bois-ecorce);">
                    Votre panier a été conservé. Vous pouvez réessayer ou nous contacter si le problème persiste.
                </p>
                <div style="margin-top: 40px; display: flex; flex-direction: column; gap: 15px; align-items: center;">
                    <a href="/panier" class="filter-btn active" style="text-decoration: none; display: inline-block;">
                        Retourner au panier
                    </a>
                    <a href="/boutique" class="btn-continue-shopping" style="text-decoration: none;">
                        Continuer mes achats
                    </a>
                </div>
            </div>
        </div>
    </section>
</MainLayout>