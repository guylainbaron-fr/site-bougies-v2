<div style="padding:0 8px; overflow: hidden; display: flex; flex-direction: column; justify-content: center; gap: 1px;">
    
    {/* LIGNE 1 : APPAREIL + GLOBE + IP */}
    <div style="display:flex; align-items:center; gap:8px; white-space: nowrap;">
        <span style="font-size:0.9rem;">
            {!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? (
                <i class="fa-solid fa-robot" style="color: #9b59b6;"></i> 
            ) : (
                <>
                    {log.device === 'iOS' && <i class="fa-brands fa-apple"></i>}
                    {log.device === 'Android' && <i class="fa-brands fa-android"></i>}
                    {(log.device === 'Ordinateur' || log.device === 'PC') && <i class="fa-solid fa-desktop"></i>}
                </>
            )}
        </span>
        
        {/* TOUJOURS LE GLOBE EN L1 : VIOLET POUR ROBOT | DORE POUR HUMAIN */}
