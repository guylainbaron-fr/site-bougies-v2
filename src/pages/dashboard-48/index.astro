            target="_blank" 
            style={`font-size:0.7rem; font-weight:800; text-decoration: none; 
                color: ${!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? '#9b59b6' : 'inherit'}; 
                border-bottom: 1px dashed ${!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? '#9b59b6' : 'var(--sable-dore)'};`}
        >
            {log.ip && log.ip !== 'Privé' ? log.ip : "Privé"}
        </a>
        {/* BOUTON BAN : Uniquement si l'IP n'est pas "Privé" */}
        {log.ip && log.ip !== 'Privé' && (
            <button 
                onclick={`banIP('${log.ip}')`}
                title="Bannir cette IP"
                style="background:none; border:none; color:#e63946; cursor:pointer; padding:0; margin-left:4px; display:flex; align-items:center;"
                >
                <i class="fa-solid fa-hand" style="font-size: 0.65rem;"></i>
            </button>
        )}
    </div>

    {/* LIGNE 2 : PROVENANCE */}
<div style="font-size:0.6rem; font-weight:900; display:flex; align-items:center; gap:5px; text-transform: uppercase;">
    {!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? (
        /* Cas ROBOT : SERVEUR + NOM DU ROBOT en VIOLET */
        <>
            <i class="fa-solid fa-server" style="color: #9b59b6;"></i>
            <span style="color: #9b59b6;">{log.device}</span>
        </>
    ) : (
        /* Cas HUMAIN : QR, Social ou Lien Web */
        <>
            {(log.isQR === true || String(log.isQR) === 'true') ? (
                <>
                    <i class="fa-solid fa-qrcode" style="color: var(--color-qr);"></i>
                    <span style="color: var(--color-qr);">Scan QR</span>
                </>
            ) : (
                <>
                    {log.source === 'Instagram' && <i class="fa-brands fa-instagram" style="color: #E1306C;"></i>}
                    {log.source === 'Facebook' && <i class="fa-brands fa-facebook" style="color: #1877F2;"></i>}
                    {log.source === 'WhatsApp' && <i class="fa-brands fa-whatsapp" style="color: #25D366;"></i>}
                    {log.source === 'TikTok' && <i class="fa-brands fa-tiktok" style="color: #000000;"></i>}
                    {log.source === 'Pinterest' && <i class="fa-brands fa-pinterest" style="color: #E60023;"></i>}
                    
                    {(!log.source || log.source === 'Direct' || log.source === 'Inconnue') && (
                        <>
                            <i class="fa-solid fa-link" style="color: var(--color-direct);"></i>
                            <span style="color: var(--color-direct);">LIEN WEB</span>
                        </>
                    )}

                    {/* Affichage du texte pour les réseaux (Insta, FB, WA, TikTok, Pinterest) */}
                    {log.source && ['Instagram', 'Facebook', 'WhatsApp', 'TikTok', 'Pinterest'].includes(log.source) && (
                        <span style={`color: ${
                            log.source === 'Instagram' ? '#E1306C' : 
                            log.source === 'Facebook' ? '#1877F2' : 
                            log.source === 'WhatsApp' ? '#25D366' : 
                            log.source === 'TikTok' ? '#000000' : 
                            '#E60023' // Pinterest
                        };`}>{log.source}</span>
                    )}

                    {log.source && !['Instagram', 'Facebook', 'WhatsApp', 'TikTok', 'Pinterest', 'Direct', 'Inconnue'].includes(log.source) && (
                        <span>{log.source}</span>
                    )}
                </>
            )}
        </>
    )}
</div>

    {/* LIGNE 3 : PAYS */}
    <div style="font-size:0.55rem; font-weight:900; opacity:0.8; display:flex; align-items:center; gap:5px;">
        <div style="position: relative; width: 14px; height: 10px; flex-shrink: 0; overflow: hidden;">
            {log.flag_code && <img src={`https://flagcdn.com/${log.flag_code}.svg`} width="14" height="10" style="display: block; object-fit: cover;" />}
            {(!log.flag_code || log.flag_code === 'un') && <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: #f2e1a6; border: 1px solid var(--sable-dore);"></div>}
        </div>
        <span>{log.country || 'INCONNU'}</span>
    </div>
</div>

        <div class="log-cell-right">
            <span>{timeS}</span>
            <span style="font-size:0.55rem; opacity:0.7;">{dateS}</span>
        </div>
    </div>
);
        })}
    </div>
</div>
<footer class="dashboard-footer">
    <p>&copy; {new Date().getFullYear()} Jean François & Aniuta — Dashboard Atelier</p>
</footer>
