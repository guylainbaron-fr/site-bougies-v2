<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="robots" content="noindex, nofollow">
    <title>Dashboard Atelier | J.F. & Aniuta</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta name="theme-color" content="#fdfaf7">
    <style>
    :root { 
        --sable-dore: #e0c297; 
        --vanille-pure: #fcf4dd; 
        --brun-coco: #4a3728; 
        --fond-ecume: #fdfaf7;
        --font-principale: "Poppins", sans-serif;
        --color-ios: #2980b9; --color-android: #27ae60; --color-pc: #7f8c8d;
        --color-qr: #d35400; --color-direct: #2c3e50;
    }

    /* Reset global pour forcer les bordures vers l'intérieur */
    * { box-sizing: border-box; }

    body { font-family: var(--font-principale); background-color: var(--fond-ecume); color: var(--brun-coco); margin: 0; padding: 15px; overflow-x: hidden; }
    
    .dashboard-container { max-width: 1200px; margin: 0 auto; background: white; padding: 20px; border-radius: 4px; border: 1px solid var(--sable-dore); }

    a[href^="https://ipinfo.io/"]:hover {
    color: var(--sable-dore) !important;
    cursor: crosshair; /* Un petit viseur pour le côté "investigation" */
    }

    /* HEADER RESPONSIVE */
    .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; border-bottom: 2px solid var(--sable-dore); padding-bottom: 15px; flex-wrap: wrap; gap: 15px; }
    .header-flex h1 { margin: 0; text-transform: uppercase; letter-spacing: 1px; font-size: 0.9rem; color: var(--brun-coco); display: flex; align-items: center; gap: 10px; }
    
    .nav-right { display: flex; align-items: center; gap: 15px; flex-wrap: wrap; }
    .social-mini-nav { display: flex; gap: 20px; border-right: 1px solid var(--sable-dore); padding-right: 15px; }
    .social-mini-nav a { color: var(--brun-coco); font-size: 1.5rem; text-decoration: none; }

    .btn-group { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
    .btn { padding: 8px 12px; border-radius: 4px; text-decoration: none; font-weight: 700; text-transform: uppercase; font-size: 0.6rem; cursor: pointer; border: 1px solid var(--sable-dore); display: flex; align-items: center; gap: 6px; color: var(--brun-coco); background: white; white-space: nowrap; }
    .btn-gold { background: var(--vanille-pure); }

    /* GRILLE STATS */
    .stats-row { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 25px; }
    .stat-card-mini { padding: 15px 5px; border-radius: 4px; display: flex; flex-direction: column; text-align: center; justify-content: center; color: white; font-weight: bold; min-width: 0; }
    
    .card-total { background: var(--color-direct); }
    .card-qr { background: var(--color-qr); }
    .card-ios { background: var(--color-ios); }
    .card-android { background: var(--color-android); }
    .card-pc { background: var(--color-pc); }
    .card-clock { background: var(--brun-coco); color: white; border: none; }
    .stat-card-mini .val { font-size: 1.4rem; font-weight: 800; }
    .stat-card-mini .label { font-size: 0.55rem; text-transform: uppercase; margin-top: 5px; opacity: 0.9; }

    /* BARS & LEGENDS */
    .dist-section { margin-bottom: 25px; }
    .dist-header { display: inline-flex; align-items: center; gap: 10px; padding: 6px 12px; border-radius: 4px; font-size: 0.6rem; font-weight: 800; text-transform: uppercase; margin-bottom: 10px; border: 1.5px solid var(--sable-dore); background: var(--vanille-pure); color: var(--brun-coco); }
    .distribution-bar { display: flex; width: 100%; height: 22px; border-radius: 4px; overflow: hidden; background-color: #eee; margin-bottom: 10px; }
    .segment { height: 100%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 900; color: white; }
    .bg-ios { background-color: var(--color-ios); }
    .bg-android { background-color: var(--color-android); }
    .bg-pc { background-color: var(--color-pc); }
    .bg-qr { background-color: var(--color-qr); }
    .bg-direct { background-color: var(--color-direct); }

    .bar-legend { display: flex; flex-wrap: wrap; gap: 15px; }
    .legend-item { display: inline-flex; align-items: center; gap: 6px; font-size: 0.6rem; font-weight: bold; text-transform: uppercase; }
    .dot { width: 10px; height: 10px; border-radius: 2px; }

    /* ACTIONS */
    .actions-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px; flex-wrap: wrap; }

    /* JOURNAL RESPONSIVE - CORRECTION TRAIT DROIT */
    .logs-section { background: white; border: 1px solid var(--sable-dore); padding: 15px; border-radius: 4px; width: 100%; }
    .logs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; width: 100%; }
    .log-entry { display: grid; grid-template-columns: 40px 1fr 80px; align-items: center; border: 1px solid var(--sable-dore); background: #fff; height: 65px; border-radius: 3px; overflow: hidden; }
    /* SÉCURITÉ ÉCRAN : Si le JS dit de cacher, on cache vraiment */
    .log-entry[style*="display: none"] { display: none !important; }
    .log-cell-num { background: var(--vanille-pure); height: 100%; display: flex; align-items: center; justify-content: center; border-right: 1px solid var(--sable-dore); font-weight: 900; font-family: monospace; font-size: 0.8rem; }
    .log-cell-right { border-left: 1px solid var(--sable-dore); height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--fond-ecume); font-size: 0.65rem; font-weight: 800; }

    /* FILTRES : Centrés et Responsive */
    .filter-bar { 
        display: flex; 
        justify-content: center; /* CENTRE LA BARRE */
        flex-wrap: wrap; 
        gap: 8px; 
        margin-bottom: 25px; /* Un peu plus d'espace sous la barre */
        padding: 10px 5px;
        overflow: visible;
    }

    .filter-btn { 
        background: white; 
        border: 1px solid var(--sable-dore); 
        padding: 7px 12px; 
        border-radius: 4px; 
        font-size: 0.65rem; 
        font-weight: 800; 
        text-transform: uppercase; 
        letter-spacing: 0.5px; 
        color: var(--brun-coco); 
        cursor: pointer; 
        display: flex; 
        align-items: center; 
        gap: 8px; 
        white-space: nowrap; 
        transition: all 0.2s ease;
        /* CONFIGURATION CLÉ */
        flex: 0 1 auto; /* Garde la taille naturelle du bouton, ne force pas l'étirement */
        margin-bottom: 5px;
    }

    .filter-btn.active { 
        background: var(--brun-coco) !important; 
        color: var(--vanille-pure) !important; 
        border-color: var(--brun-coco) !important; 
    }

    .badge { background: var(--vanille-pure); color: var(--brun-coco); padding: 2px 6px; border-radius: 3px; font-size: 0.6rem; font-family: monospace; font-weight: 900; }
    .filter-btn.active .badge { background: white !important; color: var(--brun-coco) !important; }
    .filter-btn:not(.active):hover { background: var(--fond-ecume); border-color: var(--brun-coco); }

.dashboard-footer {
    margin-top: 30px;
    padding: 20px 0;
    border-top: 1px solid var(--sable-dore);
    text-align: center;
}

.dashboard-footer p {
    margin: 0;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 800;
    color: var(--brun-coco);
    opacity: 0.6;
}

    /* MEDIA QUERIES */
    @media (max-width: 1024px) {
        .stats-row { grid-template-columns: repeat(3, 1fr); }
        .logs-grid { grid-template-columns: repeat(2, 1fr); }
    }

/* MEDIA QUERIES FUSIONNÉE */
    @media (max-width: 650px) {
        .header-flex { 
            flex-direction: column; 
            align-items: center; /* Centré pour un look plus propre sur mobile */
            text-align: center;
        }

        .nav-right { 
            width: 100%; 
            flex-direction: column; /* Empile les réseaux sociaux et les boutons */
            gap: 15px;
            align-items: center;
        }

        .social-mini-nav { 
            border-right: none; 
            padding-right: 0; 
            padding-bottom: 5px;
            justify-content: center;
        }

        .btn-group { 
            display: flex;
            flex-wrap: wrap; /* Les boutons passent à la ligne si besoin */
            justify-content: center;
            gap: 8px;
            width: 100%;
        }

        .btn { 
            font-size: 0.55rem; 
            padding: 8px 10px;
            flex: 1 1 auto; /* Les boutons s'étirent pour remplir la largeur proprement */
            justify-content: center;
        }

        .stats-row { grid-template-columns: repeat(2, 1fr); }
        .logs-grid { grid-template-columns: 1fr; }
        
        .actions-row { flex-direction: column; align-items: stretch; }
        .actions-row .btn { justify-content: center; }
        
        .filter-bar { margin-left: -5px; padding-left: 5px; }
    }

/* --- IMPRESSION OPTIMISÉE (3 COLONNES = ÉCONOMIE DE PAPIER) --- */
    @media print {
        /* SÉCURITÉ IMPRESSION : On ne sort pas sur le papier ce qui est filtré */
    .log-entry[style*="display: none"] {
        display: none !important;
    }
        @page { 
            margin: 8mm; 
            size: portrait; 
        }
        body { 
            padding: 0 !important; 
            background: white !important; 
            font-size: 9pt; 
        }
        
        /* Conteneur pleine largeur */
        .dashboard-container { 
            border: none !important; 
            width: 100% !important; 
            max-width: none !important; 
            padding: 0 !important; 
        }
        
        /* Cacher l'inutile */
        .nav-right, .actions-row, .social-mini-nav, #confirmReset, .dashboard-footer, .btn-group { 
            display: none !important; 
        }

        .logs-section { 
            border: none !important; 
            padding: 0 !important; 
            width: 100% !important; 
        }
        
        /* Grille en 3 colonnes */
        .logs-grid { 
            display: grid !important; 
            grid-template-columns: repeat(3, 1fr) !important; 
            gap: 5px !important; /* Gap réduit pour gagner de la place */
            width: 100% !important; 
        }
        
        .log-entry { 
            display: grid !important; 
            /* On réduit les côtés (25px et 65px) pour donner le max à l'IP au milieu */
            grid-template-columns: 25px 1fr 65px !important; 
            width: 100% !important; 
            height: 65px !important; 
            margin-bottom: 0px !important; 
            border: 1px solid #ddd !important; 
            page-break-inside: avoid; 
            break-inside: avoid; 
        }

        /* Optimisation de l'affichage de l'IP pour éviter les coupures */
        .log-entry a { 
            font-size: 0.6rem !important; /* Plus petit pour que ça tienne */
            letter-spacing: -0.3px !important; /* Resserre les chiffres de l'IP */
            display: inline-block !important;
            word-break: break-all !important; /* Sécurité si vraiment trop long */
        }

        /* Réduction des icônes pour libérer de la largeur */
        .log-entry i {
            font-size: 0.7rem !important;
        }

        /* Petits ajustements des cellules gauche et droite */
        .log-cell-num { 
            font-size: 0.6rem !important; 
            border-right: 1px solid #ddd !important;
        }
        .log-cell-right { 
            font-size: 0.5rem !important; 
            border-left: 1px solid #ddd !important;
        }

        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    }
</style>
</head>
