    <div style="display:flex; align-items:center; gap:12px;">
        <div style="display:flex; align-items:center; gap:8px;">
            <input type="text" id="confirmReset" placeholder="RESET" style="width:70px; padding:8px; border:1px solid var(--sable); border-radius:4px; font-size:0.7rem; text-align:center; font-weight:bold;" />
            <form method="POST" style="margin:0;">
                <input type="hidden" name="action" value="reset" />
                <button type="submit" id="resetBtn" disabled style="background: var(--coco); color: white; opacity:0.5; border:none; padding:8px 12px; border-radius:4px; font-size:0.6rem; font-weight:bold; cursor:not-allowed;">EFFACER</button>
            </form>
        </div>

        {/* Affichage de la date du dernier reset */}
        <div style="display: flex; flex-direction: column; border-left: 1px solid var(--sable); padding-left: 12px;">
            <span style="font-size: 0.5rem; text-transform: uppercase; font-weight: 800; opacity: 0.5; letter-spacing: 0.5px;">Dernier Reset</span>
            <span style="font-size: 0.65rem; font-weight: 700; color: var(--coco);">{lastResetDate}</span>
        </div>
    </div>
</div>

        <div class="logs-section">
            <div style="font-weight:900; text-transform:uppercase; font-size:0.65rem; margin-bottom:12px; border-bottom:1px solid var(--vanille-pure); padding-bottom:8px; color: var(--brun-coco);">
                Journal des passages (138 DERNIERS)
            </div>

            <div class="filter-bar">
                <button class="filter-btn active" onclick="filterLogs('all')">
                    <i class="fa-solid fa-list"></i> Tous <span class="badge" id="count-all">0</span>
                </button>
                <button class="filter-btn" onclick="filterLogs('qr')">
                    <i class="fa-solid fa-qrcode"></i> QR Code <span class="badge" id="count-qr">0</span>
                </button>
                <button class="filter-btn" onclick="filterLogs('social')">
                    <i class="fa-solid fa-share-nodes"></i> Social <span class="badge" id="count-social">0</span>
                </button>
                <button class="filter-btn" onclick="filterLogs('mobile')">
                    <i class="fa-solid fa-mobile-screen"></i> Mobiles <span class="badge" id="count-mobile">0</span>
                </button>
                <button class="filter-btn" onclick="filterLogs('pc')">
                    <i class="fa-solid fa-desktop"></i> Ordinateur <span class="badge" id="count-pc">0</span>
                </button>
                <button class="filter-btn" onclick="filterLogs('bot')">
                    <i class="fa-solid fa-robot"></i> Robots <span class="badge" id="count-bot">0</span>
                </button>
                <button class="filter-btn" onclick="filterLogs('france')">
                    <i class="fa-solid fa-flag"></i> France <span class="badge" id="count-france">0</span>
                </button>
                <button class="filter-btn" onclick="filterLogs('international')">
                    <i class="fa-solid fa-earth-americas"></i> Hors France <span class="badge" id="count-intl">0</span>
                </button>
            </div>
    <div class="logs-grid">
        {logs.map((log, index) => {
    const [dateS, timeS] = (log.date || " - ").split(' ');
    
// --- LOGIQUE DE L'ICÔNE (QR / Globe / Plug / Secret) ---
let connectionIcon = "fa-user-secret";
let connectionLabel = "Privé";
let iconColor = "var(--sable-dore)"; // Couleur dorée par défaut

if (log.isQR === true || String(log.isQR) === 'true') {
    connectionIcon = "fa-qrcode";
    connectionLabel = "Scan QR";
    iconColor = "#ff8c00"; // Orange pour le QR <--- BIEN VÉRIFIER CECI
} else if (log.ip === '::1' || log.ip === '127.0.0.1') {
    connectionIcon = "fa-plug";
    connectionLabel = "Local";
} else if (log.ip && log.ip !== 'Privé' && log.ip !== 'IP Inconnue') {
    connectionIcon = "fa-globe";
    connectionLabel = log.ip;
}

            // On garde TOUJOURS l'IP (ou le nom du Bot) pour la ligne du haut
            let displayName = (log.ip && log.ip !== 'Privé' && log.ip !== 'IP Inconnue') ? log.ip : "Privé";

            // Si c'est un bot, on affiche son nom
            const isHuman = ['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device);
            if (!isHuman) {
            displayName = log.device; 
            }

return (
    <article class="log-entry" 
     data-qr={String(log.isQR === true || String(log.isQR) === 'true')} 
     data-device={log.device || 'Robot Inconnu'} 
     data-source={log.source || 'Lien Web'}
     data-country={log.country?.toUpperCase() || 'IP NON LOCALISÉE'}>
        
        <div class="log-cell-num">{logs.length - index}</div>
        
<div style="padding:0 8px; overflow: hidden; display: flex; flex-direction: column; justify-content: center; gap: 1px;">
    
    {/* LIGNE 1 : APPAREIL + GLOBE + IP */}
    <div style="display:flex; align-items:center; gap:8px; white-space: nowrap;">
        <span style="font-size:0.9rem;">
            {!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? (
                <i class="fa-solid fa-robot" style="color: #9b59b6;"></i> 
            ) : (
                <>
                    {log.device === 'iOS' && <i class="fa-brands fa-apple"></i>}
                    {log.device === 'Android' && <i class="fa-brands fa-android"></i>}
                    {(log.device === 'Ordinateur' || log.device === 'PC') && <i class="fa-solid fa-desktop"></i>}
                </>
            )}
        </span>
        
        {/* TOUJOURS LE GLOBE EN L1 : VIOLET POUR ROBOT | DORE POUR HUMAIN */}
        {!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? (
            <i class="fa-solid fa-globe" style="font-size:0.75rem; color: #9b59b6;"></i>
        ) : (
            <i class="fa-solid fa-globe" style="font-size:0.75rem; color: var(--sable-dore);"></i>
        )}
        
        {/* IP : VIOLETTE POUR ROBOT | DOREE POUR HUMAIN */}
        <a 
            href={`https://ipinfo.io/${log.ip}`} 
            target="_blank" 
            style={`font-size:0.7rem; font-weight:800; text-decoration: none; 
                color: ${!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? '#9b59b6' : 'inherit'}; 
                border-bottom: 1px dashed ${!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? '#9b59b6' : 'var(--sable)'};`}
        >
            {log.ip && log.ip !== 'Privé' ? log.ip : "Privé"}
        </a>
    </div>

    {/* LIGNE 2 : PROVENANCE */}
<div style="font-size:0.6rem; font-weight:900; display:flex; align-items:center; gap:5px; text-transform: uppercase;">
    {!['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device) ? (
        /* Cas ROBOT : SERVEUR + NOM DU ROBOT en VIOLET */
        <>
            <i class="fa-solid fa-server" style="color: #9b59b6;"></i>
            <span style="color: #9b59b6;">{log.device}</span>
        </>
    ) : (
        /* Cas HUMAIN : QR, Social ou Lien Web */
        <>
            {(log.isQR === true || String(log.isQR) === 'true') ? (
                <>
                    <i class="fa-solid fa-qrcode" style="color: var(--color-qr);"></i>
                    <span style="color: var(--color-qr);">Scan QR</span>
                </>
            ) : (
                <>
                    {log.source === 'Instagram' && <i class="fa-brands fa-instagram" style="color: #E1306C;"></i>}
                    {log.source === 'Facebook' && <i class="fa-brands fa-facebook" style="color: #1877F2;"></i>}
                    {log.source === 'WhatsApp' && <i class="fa-brands fa-whatsapp" style="color: #25D366;"></i>}
                    {log.source === 'TikTok' && <i class="fa-brands fa-tiktok" style="color: #000000;"></i>}
                    {log.source === 'Pinterest' && <i class="fa-brands fa-pinterest" style="color: #E60023;"></i>}
                    
                    {(!log.source || log.source === 'Direct' || log.source === 'Inconnue') && (
                        <>
                            <i class="fa-solid fa-link" style="color: var(--color-direct);"></i>
                            <span style="color: var(--color-direct);">LIEN WEB</span>
                        </>
                    )}

                    {/* Affichage du texte pour les réseaux (Insta, FB, WA, TikTok, Pinterest) */}
                    {log.source && ['Instagram', 'Facebook', 'WhatsApp', 'TikTok', 'Pinterest'].includes(log.source) && (
                        <span style={`color: ${
                            log.source === 'Instagram' ? '#E1306C' : 
                            log.source === 'Facebook' ? '#1877F2' : 
                            log.source === 'WhatsApp' ? '#25D366' : 
                            log.source === 'TikTok' ? '#000000' : 
                            '#E60023' // Pinterest
                        };`}>{log.source}</span>
                    )}

                    {log.source && !['Instagram', 'Facebook', 'WhatsApp', 'TikTok', 'Pinterest', 'Direct', 'Inconnue'].includes(log.source) && (
                        <>
                            <i class="fa-solid fa-link" style="color: var(--color-direct);"></i>
                            <span style="color: var(--color-direct);">{log.source}</span>
                        </>
                    )}
                </>
            )}
        </>
    )}
</div>

    {/* LIGNE 3 : PAYS */}
    <div style="font-size:0.55rem; font-weight:900; opacity:0.8; display:flex; align-items:center; gap:5px;">
        <div style="position: relative; width: 14px; height: 10px; flex-shrink: 0; overflow: hidden;">
            {log.flag_code && <img src={`https://flagcdn.com/${log.flag_code}.svg`} width="14" height="10" style="display: block; object-fit: cover;" />}
            {(!log.flag_code || log.flag_code === 'un') && <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: #f2e1a6; border: 1px solid var(--sable-dore);"></div>}
        </div>
        <span>{log.country || 'INCONNU'}</span>
    </div>
</div>

        <div class="log-cell-right">
            <span>{timeS}</span>
            <span style="font-size:0.55rem; opacity:0.7;">{dateS}</span>
        </div>
    </article>
);
        })}
    </div>
</div>
<footer class="dashboard-footer">
    <p>&copy; {currentYear} Jean François & Aniuta — Dashboard Atelier</p>
</footer>
    </div>

    <!-- MODAL GÉNÉRATEUR DE LIENS -->
    <div id="utmModal" class="modal-overlay" onclick="if(event.target === this) closeUtmModal()">
        <div class="modal-content">
            <div class="modal-header">
                <h3 style="margin:0; font-size:1rem; color: var(--coco);">GÉNÉRATEUR DE LIENS</h3>
                <button onclick="closeUtmModal()" style="background:none; border:none; cursor:pointer; font-size:1.5rem; color: var(--sable);">&times;</button>
            </div>
            
            <p style="font-size:0.7rem; color: var(--coco); opacity:0.8; line-height:1.4;">
                Cliquez sur un bouton pour copier le lien spécial. Collez-le ensuite dans vos bios ou publications pour suivre les visites.
            </p>

            <div class="utm-grid">
                <button class="utm-btn" onclick="copyUtm('fb', this)"><i class="fa-brands fa-facebook" style="color:#1877F2"></i> Facebook</button>
                <button class="utm-btn" onclick="copyUtm('ig', this)"><i class="fa-brands fa-instagram" style="color:#E1306C"></i> Instagram</button>
                <button class="utm-btn" onclick="copyUtm('wa', this)"><i class="fa-brands fa-whatsapp" style="color:#25D366"></i> WhatsApp</button>
                <button class="utm-btn" onclick="copyUtm('tk', this)"><i class="fa-brands fa-tiktok" style="color:#000"></i> TikTok</button>
                <button class="utm-btn" onclick="copyUtm('pin', this)"><i class="fa-brands fa-pinterest" style="color:#E60023"></i> Pinterest</button>
                <button class="utm-btn" onclick="copyUtm('qr', this)"><i class="fa-solid fa-qrcode" style="color:var(--color-qr)"></i> QR Code</button>
            </div>

            <div class="utm-custom-box">
                <span style="font-size:0.6rem; font-weight:800; text-transform:uppercase; display:block; margin-bottom:8px;">Source Personnalisée (ex: Partenaire)</span>
                <input type="text" id="customSourceName" class="utm-input" placeholder="NOM DU PARTENAIRE">
                <button class="btn btn-add" style="width:100%; justify-content:center;" onclick="copyCustomUtm(this)">
                    COPIER LE LIEN PARTENAIRE
                </button>
            </div>
        </div>
    </div>

<script>
    // Gestion de l'horloge
    function updateClock() {
        const now = new Date();
        const clockEl = document.getElementById('live-clock');
        const dateEl = document.getElementById('live-date');
        if (clockEl) clockEl.textContent = now.toLocaleTimeString('fr-FR');
        if (dateEl) dateEl.textContent = now.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
    }
    setInterval(updateClock, 1000); 
    updateClock();

    // Gestion du bouton Reset
    const inputReset = document.getElementById('confirmReset') as HTMLInputElement;
    const btnReset = document.getElementById('resetBtn') as HTMLButtonElement;
    
    inputReset?.addEventListener('input', (e) => {
        if ((e.target as HTMLInputElement).value.toUpperCase() === 'RESET') {
            btnReset.disabled = false;
            btnReset.style.background = '#d32f2f'; btnReset.style.opacity = '1'; btnReset.style.cursor = 'pointer';
        } else {
            btnReset.disabled = true;
            btnReset.style.background = 'var(--coco)'; btnReset.style.opacity = '0.5'; btnReset.style.cursor = 'not-allowed';
        }
    });

    // Gestion du bouton Nettoyer les Bots
    const inputBots = document.getElementById('confirmBots') as HTMLInputElement;
    const btnBots = document.getElementById('botsBtn') as HTMLButtonElement;

    inputBots?.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        if (target.value.toUpperCase() === 'ROBOTS') {
            btnBots.disabled = false;
            btnBots.style.opacity = '1';
            btnBots.style.cursor = 'pointer';
        } else {
            btnBots.disabled = true;
            btnBots.style.opacity = '0.5';
            btnBots.style.cursor = 'not-allowed';
        }
    });

    // --- LOGIQUE GÉNÉRATEUR UTM ---
    (window as any).openUtmModal = () => {
        document.getElementById('utmModal')!.style.display = 'flex';
    };

    (window as any).closeUtmModal = () => {
        document.getElementById('utmModal')!.style.display = 'none';
    };

    (window as any).copyUtm = (source: string, btn: HTMLElement) => {
        const baseUrl = window.location.origin;
        const finalUrl = `${baseUrl}/?utm_source=${source}`;
        navigator.clipboard.writeText(finalUrl).then(() => {
            const original = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-check"></i> COPIÉ !';
            btn.classList.add('success-state');
            setTimeout(() => {
                btn.innerHTML = original;
                btn.classList.remove('success-state');
            }, 2000);
        });
    };

    (window as any).copyCustomUtm = (btn: HTMLElement) => {
        const input = document.getElementById('customSourceName') as HTMLInputElement;
        const source = input.value.trim() || "Partenaire";
        const baseUrl = window.location.origin;
        // On remplace les espaces par des tirets pour l'URL
        const sanitizedSource = source.toLowerCase().replace(/\s+/g, '-');
        const finalUrl = `${baseUrl}/?utm_source=${sanitizedSource}`;
        
        navigator.clipboard.writeText(finalUrl).then(() => {
            const originalBtnText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-check"></i> LIEN COPIÉ !';
            btn.classList.add('btn-success-state');
            input.classList.add('success-state');
            
            setTimeout(() => {
                btn.innerHTML = originalBtnText;
                btn.classList.remove('btn-success-state');
                input.classList.remove('success-state');
                input.value = "";
            }, 2000);
        });
    };
</script>
<script is:inline>
// Fonction pour calculer les badges au chargement
function updateBadges() {
    const entries = document.querySelectorAll('.log-entry');
    let counts = { all: 0, qr: 0, social: 0, mobile: 0, pc: 0, france: 0, intl: 0, bot: 0 };

    entries.forEach(entry => {
        // 1. RÉCUPÉRATION DES DONNÉES (Ordre corrigé pour éviter l'erreur de variable)
        const source = entry.getAttribute('data-source') || 'Direct'; 
        const isQR = entry.getAttribute('data-qr') === 'true' || source.toLowerCase() === 'qr';
        const device = entry.getAttribute('data-device') || 'Inconnu';
        const country = entry.getAttribute('data-country') || 'INCONNU';
        
        // 2. DÉFINITION DES GROUPES
        const isBot = !['iOS', 'Android', 'PC', 'Ordinateur'].includes(device);
        const isSocial = ['Instagram', 'Facebook', 'WhatsApp', 'TikTok', 'Twitter', 'Pinterest'].includes(source);

        counts.all++;
        
        // 3. INC RÉMENTATION DES COMPTEURS
        if (isQR) counts.qr++;
        if (isSocial) counts.social++;
        
        if (isBot) {
            counts.bot++;
        } else {
            if (device === 'iOS' || device === 'Android') counts.mobile++;
            if (device === 'PC' || device === 'Ordinateur') counts.pc++;
        }

        if (!isBot) {
            if (country.toUpperCase() === 'FRANCE') counts.france++;
            else counts.intl++;
        }
    });

    // Mise à jour visuelle des badges
    const setBadge = (id, value) => {
        const el = document.getElementById(id);
        if (el) el.innerText = value;
    };

    setBadge('count-all', counts.all);
    setBadge('count-qr', counts.qr);
    setBadge('count-social', counts.social);
    setBadge('count-mobile', counts.mobile);
    setBadge('count-pc', counts.pc);
    setBadge('count-france', counts.france);
    setBadge('count-intl', counts.intl);
    setBadge('count-bot', counts.bot);
}

// Fonction de filtrage complète
function filterLogs(type) {
    const entries = document.querySelectorAll('.log-entry');
    const buttons = document.querySelectorAll('.filter-btn');

    // Gestion de l'état actif des boutons
    buttons.forEach(btn => btn.classList.remove('active'));
    if (window.event && window.event.currentTarget) {
        window.event.currentTarget.classList.add('active');
    }

entries.forEach(entry => {
    // 1. RÉCUPÉRATION DES DONNÉES (Inchangé)
    const source = entry.getAttribute('data-source') || 'Direct';
    const isQR = entry.getAttribute('data-qr') === 'true' || source.toLowerCase() === 'qr';
    const device = entry.getAttribute('data-device') || 'Inconnu';
    const country = entry.getAttribute('data-country') || 'INCONNU';
    
    const isBot = !['iOS', 'Android', 'PC', 'Ordinateur'].includes(device);
    const isSocial = ['Instagram', 'Facebook', 'WhatsApp', 'TikTok', 'Twitter', 'Pinterest'].includes(source);

    // 2. LOGIQUE DE FILTRAGE
    let show = false;

    if (type === 'all') {
        show = true;
    } 
    else if (type === 'qr' && isQR) {
        show = true;
    } 
    else if (type === 'social' && isSocial) {
        show = true;
    } 
    else if (type === 'bot' && isBot) {
        show = true;
    } 
    else if (type === 'mobile' && !isBot && (device === 'iOS' || device === 'Android')) {
        show = true;
    } 
    else if (type === 'pc' && !isBot && (device === 'PC' || device === 'Ordinateur')) {
        show = true;
    } 
    else if (type === 'france' && !isBot && country.toUpperCase() === 'FRANCE') {
        show = true;
    } 
    else if (type === 'international' && !isBot && country.toUpperCase() !== 'FRANCE') {
        show = true;
    }

    // 3. AFFICHAGE
    entry.style.display = show ? 'grid' : 'none';
});
}


// Fonction d'export CSV
function exportLogsToCSV() {
    const entries = document.querySelectorAll('.log-entry');
    
    // --- MODIF 3 : NOM DE FICHIER DYNAMIQUE ---
    // On récupère le nom du filtre actif (ex: "Robots", "QR", etc.)
    const activeFilterBtn = document.querySelector('.filter-btn.active');
    let filterName = "Tous";
    if (activeFilterBtn) {
        // On nettoie le texte pour enlever les chiffres du badge et les icônes
        filterName = activeFilterBtn.innerText.replace(/[0-9]/g, '').trim();
    }

    // On définit les colonnes : N°, IP, SOURCE, APPAREIL, PAYS, HEURE, DATE
    let csvContent = "N°;IP;SOURCE;APPAREIL;PAYS;HEURE;DATE\r\n"; 

    entries.forEach(entry => {
        if (entry.style.display !== 'none') {
            const num = entry.querySelector('.log-cell-num')?.innerText.trim() || "";
            const sourceIP = entry.querySelector('a')?.innerText.trim() || "Privé";
            const source = entry.getAttribute('data-source') || "Direct";
            const device = entry.getAttribute('data-device') || "Inconnu";
            const pays = entry.getAttribute('data-country') || "Inconnu";
            const rightCell = entry.querySelector('.log-cell-right');
            const heure = rightCell?.querySelector('span:first-child')?.innerText.trim() || "";
            const date = rightCell?.querySelector('span:last-child')?.innerText.trim() || "";

            // On assemble tout proprement
            const rowData = [num, sourceIP, source, device, pays, heure, date]
                .map(text => `"${text.replace(/"/g, '""')}"`)
                .join(";");
            
            csvContent += rowData + "\r\n";
        }
    });

    // Génération du fichier
    const BOM = "\uFEFF";
    const blob = new Blob([BOM + csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    const dateFile = new Date().toLocaleDateString('fr-FR').replace(/\//g, '-');

    // Nom de fichier auto-ajusté (ex: logs_Robots_07-03-2026.csv)
    link.setAttribute("href", url);
    link.setAttribute("download", `logs_${filterName}_${dateFile}.csv`);
    
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
}

// LANCEMENT AU CHARGEMENT
window.addEventListener('load', () => {
    if (typeof updateBadges === 'function') updateBadges();
});
</script>
