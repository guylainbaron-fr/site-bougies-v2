---
const currentYear = new Date().getFullYear();
export const prerender = false;

import { kv } from "../../lib/kv";
import AdminHeader from "../../components/AdminHeader.astro";
import '../../styles/admin.css';

interface LogEntry {
    device: string;
    ip?: string;
    isQR?: boolean | string;
    source?: string;
    date: string;
    country?: string;
    flag_code?: string;
}

// GESTION DES ACTIONS (Reset ou Nettoyage Bots)
if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get("action");

        if (action === "reset") {
            await kv.set('visites_totales', 0);
            await kv.del('journal_visites');
            const dateAction = new Date().toLocaleString('fr-FR', { 
                timeZone: 'Europe/Paris',
                day: '2-digit', month: '2-digit', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
            await kv.set('date_dernier_reset', dateAction);
            return Astro.redirect('/dashboard-48'); 
        }

        if (action === "clean_bots") {
            const allLogs = (await kv.lrange('journal_visites', 0, -1)) || [];
            const cleanLogs = allLogs.filter((item: any) => {
                const log: LogEntry = typeof item === 'string' ? JSON.parse(item) : item;
                return ['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device);
            });

            await kv.del('journal_visites');
            if (cleanLogs.length > 0) {
                const logsToPush = [...cleanLogs].reverse();
                for (const log of logsToPush) {
                    await kv.lpush('journal_visites', JSON.stringify(log));
                }
            }

            const dateAction = new Date().toLocaleString('fr-FR', { 
                timeZone: 'Europe/Paris',
                day: '2-digit', month: '2-digit', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
            await kv.set('date_dernier_clean_bots', dateAction);

            return Astro.redirect('/dashboard-48');
        }
    } catch (e) {
        console.error("Erreur Action:", e);
    }
}

// --- INITIALISATION DES VARIABLES ---
let totalVisites = 0;
let logs: LogEntry[] = [];
let iosCount = 0;
let androidCount = 0;
let pcCount = 0;
let botCount = 0; 
let qrCount = 0;
let lastResetDate = "";
let lastCleanBotsDate = "";

// --- RÉCUPÉRATION DES DONNÉES ---
try {
    totalVisites = (await kv.get<number>('visites_totales')) || 0;
    lastResetDate = await kv.get<string>('date_dernier_reset') || "Inconnue";
    lastCleanBotsDate = await kv.get<string>('date_dernier_clean_bots') || "Jamais";
    const rawLogs = (await kv.lrange('journal_visites', 0, 137)) || []; 
    
    logs = rawLogs.map((item: any) => {
        const log: LogEntry = typeof item === 'string' ? JSON.parse(item) : item;
        
        // Logique : Si c'est dans la liste, c'est humain. Sinon, c'est un Bot.
        const isHuman = ['iOS', 'Android', 'PC', 'Ordinateur'].includes(log.device);
        
        if (!isHuman) {
            botCount++;
        } else {
            if (log.device === "iOS") iosCount++;
            else if (log.device === "Android") androidCount++;
            else if (log.device === "Ordinateur" || log.device === "PC") pcCount++;
        }
        
        if (log.isQR === true || String(log.isQR) === 'true') qrCount++;
        return log;
    });
} catch (e) {
    console.error("Erreur de récupération KV:", e);
}

// --- 1. CALCULS DES TOTAUX ---
const totalVisitesHumaines = iosCount + androidCount + pcCount;
const totalAvecBots = totalVisitesHumaines + botCount;

// --- 2. CALCULS POUR LA BARRE TECHNOLOGIE (Humains + Bots) ---
// On calcule les % bruts
let iosPct = totalAvecBots > 0 ? Math.round((iosCount / totalAvecBots) * 100) : 0;
let androidPct = totalAvecBots > 0 ? Math.round((androidCount / totalAvecBots) * 100) : 0;
let pcPct = totalAvecBots > 0 ? Math.round((pcCount / totalAvecBots) * 100) : 0;
// Le dernier segment (Bots) prend le reste pour toujours arriver à pile 100%
let botPct = totalAvecBots > 0 ? (100 - iosPct - androidPct - pcPct) : 0;
if (botPct < 0) botPct = 0; // Sécurité

// --- 3. CALCULS POUR LA BARRE ORIGINE (Humains uniquement) ---
let qrPct = totalVisitesHumaines > 0 ? Math.round((qrCount / totalVisitesHumaines) * 100) : 0;
let directPct = totalVisitesHumaines > 0 ? (100 - qrPct) : 0;
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="robots" content="noindex, nofollow">
    <title>Dashboard Atelier | J.F. & Aniuta</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta name="theme-color" content="#fdfaf7">
    <style>
    :root { 
        --violet: #9b59b6;
        --color-ios: #2980b9; 
        --color-android: #27ae60; 
        --color-pc: #7f8c8d;
        --color-qr: #d35400; 
        --color-direct: #2c3e50;
    }

    .stats-row { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 25px; }
    .stat-card-mini { padding: 15px 5px; border-radius: 8px; display: flex; flex-direction: column; text-align: center; color: white; font-weight: bold; }
    .card-total { background: var(--color-direct); }
    .card-qr { background: var(--color-qr); }
    .card-ios { background: var(--color-ios); }
    .card-android { background: var(--color-android); }
    .card-pc { background: var(--color-pc); }
    .card-clock { background: var(--coco); }
    .stat-card-mini .val { font-size: 1.4rem; font-weight: 800; }
    .stat-card-mini .label { font-size: 0.55rem; text-transform: uppercase; margin-top: 5px; opacity: 0.9; }

    /* BARS & LEGENDS */
    .dist-section { margin-bottom: 25px; }
    .dist-header { display: inline-flex; align-items: center; gap: 10px; padding: 6px 12px; border-radius: 4px; font-size: 0.6rem; font-weight: 800; text-transform: uppercase; margin-bottom: 10px; border: 1.5px solid var(--sable); background: var(--vanille); color: var(--coco); }
    .distribution-bar { display: flex; width: 100%; height: 22px; border-radius: 4px; overflow: hidden; background-color: #eee; margin-bottom: 10px; }
    .segment { height: 100%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 900; color: white; overflow: hidden; white-space: nowrap; }
    .bg-ios { background-color: var(--color-ios); }
    .bg-android { background-color: var(--color-android); }
    .bg-pc { background-color: var(--color-pc); }
    .bg-qr { background-color: var(--color-qr); }
    .bg-direct { background-color: var(--color-direct); }

    .bar-legend { display: flex; flex-wrap: wrap; gap: 15px; }
    .legend-item { display: inline-flex; align-items: center; gap: 6px; font-size: 0.6rem; font-weight: bold; text-transform: uppercase; }
    .dot { width: 10px; height: 10px; border-radius: 2px; }

    /* ACTIONS */
    .actions-row { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 25px; gap: 15px; flex-wrap: wrap; background: #fafafa; padding: 15px; border-radius: 8px; border: 1px solid #eee; }

    /* JOURNAL RESPONSIVE - CORRECTION TRAIT DROIT */
    .logs-section { background: white; border: 1px solid var(--sable); padding: 15px; border-radius: 4px; width: 100%; }
    .logs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; width: 100%; }
    .log-entry { display: grid; grid-template-columns: 40px 1fr 80px; align-items: center; border: 1px solid var(--sable); background: #fff; height: 65px; border-radius: 3px; overflow: hidden; }
    /* SÉCURITÉ ÉCRAN : Si le JS dit de cacher, on cache vraiment */
    .log-entry[style*="display: none"] { display: none !important; }
    .log-cell-num { background: var(--vanille); height: 100%; display: flex; align-items: center; justify-content: center; border-right: 1px solid var(--sable); font-weight: 900; font-family: monospace; font-size: 0.8rem; }
    .log-cell-right { border-left: 1px solid var(--sable); height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--fond); font-size: 0.65rem; font-weight: 800; }

    /* FILTRES : Centrés et Responsive */
    .filter-bar { 
        display: flex; 
        justify-content: center; /* CENTRE LA BARRE */
        flex-wrap: wrap; 
        gap: 8px; 
        margin-bottom: 25px; /* Un peu plus d'espace sous la barre */
        padding: 10px 5px;
        overflow: visible;
    }

    .filter-btn { 
        background: white; 
        border: 1px solid var(--sable); 
        padding: 7px 12px; 
        border-radius: 4px; 
        font-size: 0.65rem; 
        font-weight: 800; 
        text-transform: uppercase; 
        letter-spacing: 0.5px; 
        color: var(--coco); 
        cursor: pointer; 
        display: flex; 
        align-items: center; 
        gap: 8px; 
        white-space: nowrap; 
        transition: all 0.2s ease;
        /* CONFIGURATION CLÉ */
        flex: 0 1 auto; /* Garde la taille naturelle du bouton, ne force pas l'étirement */
        margin-bottom: 5px;
    }

    .filter-btn.active { 
        background: var(--coco) !important; 
        color: var(--vanille) !important; 
        border-color: var(--coco) !important; 
    }

    .badge { background: var(--vanille); color: var(--coco); padding: 2px 6px; border-radius: 3px; font-size: 0.6rem; font-family: monospace; font-weight: 900; }
    .filter-btn.active .badge { background: white !important; color: var(--coco) !important; }
    .filter-btn:not(.active):hover { background: var(--fond); border-color: var(--coco); }

.dashboard-footer {
    margin-top: 30px;
    padding: 20px 0;
    border-top: 1px solid var(--sable);
    text-align: center;
}

.dashboard-footer p {
    margin: 0;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 800;
    color: var(--coco);
    opacity: 0.6;
}

    /* MEDIA QUERIES */
    @media (max-width: 1024px) {
        .stats-row { grid-template-columns: repeat(3, 1fr); }
        .logs-grid { grid-template-columns: repeat(2, 1fr); }
    }

/* MEDIA QUERIES FUSIONNÉE */
    @media (max-width: 650px) {
        .header-flex { 
            flex-direction: column; 
            align-items: center; /* Centré pour un look plus propre sur mobile */
            text-align: center;
        }

        .nav-right { 
            width: 100%; 
            flex-direction: column; /* Empile les réseaux sociaux et les boutons */
            gap: 15px;
            align-items: center;
        }

        .social-mini-nav { 
            border-right: none; 
            padding-right: 0; 
            padding-bottom: 5px;
            justify-content: center;
        }

        .btn-group { 
            display: flex;
            flex-wrap: wrap; /* Les boutons passent à la ligne si besoin */
            justify-content: center;
            gap: 8px;
            width: 100%;
        }

        .btn { 
            font-size: 0.55rem; 
            padding: 8px 10px;
            flex: 1 1 auto; /* Les boutons s'étirent pour remplir la largeur proprement */
            justify-content: center;
        }

        .stats-row { grid-template-columns: repeat(2, 1fr); }
        .logs-grid { grid-template-columns: 1fr; }
        
        .actions-row { flex-direction: column; align-items: stretch; }
        .actions-row .btn { justify-content: center; }
        
        .filter-bar { margin-left: -5px; padding-left: 5px; }
    }

/* --- IMPRESSION OPTIMISÉE (3 COLONNES = ÉCONOMIE DE PAPIER) --- */
    @media print {
        /* SÉCURITÉ IMPRESSION : On ne sort pas sur le papier ce qui est filtré */
    .log-entry[style*="display: none"] {
        display: none !important;
    }
        @page { 
            margin: 8mm; 
            size: portrait; 
        }
        body { 
            padding: 0 !important; 
            background: white !important; 
            font-size: 9pt; 
        }
        
        /* Conteneur pleine largeur */
        .dashboard-container { 
            border: none !important; 
            width: 100% !important; 
            max-width: none !important; 
            padding: 0 !important; 
        }
        
        /* Cacher l'inutile */
        /* Les éléments à cacher sont maintenant gérés dans admin.css */

        .logs-section { 
            border: none !important; 
            padding: 0 !important; 
            width: 100% !important; 
        }
        
        /* Grille en 3 colonnes */
        .logs-grid { 
            display: grid !important; 
            grid-template-columns: repeat(3, 1fr) !important; 
            gap: 5px !important; /* Gap réduit pour gagner de la place */
            width: 100% !important; 
        }
        
        .log-entry { 
            display: grid !important; 
            /* On réduit les côtés (25px et 65px) pour donner le max à l'IP au milieu */
            grid-template-columns: 25px 1fr 65px !important; 
            width: 100% !important; 
            height: 65px !important; 
            margin-bottom: 0px !important; 
            border: 1px solid #ddd !important; 
            page-break-inside: avoid; 
            break-inside: avoid; 
        }

        /* Optimisation de l'affichage de l'IP pour éviter les coupures */
        .log-entry a { 
            font-size: 0.6rem !important; /* Plus petit pour que ça tienne */
            letter-spacing: -0.3px !important; /* Resserre les chiffres de l'IP */
            display: inline-block !important;
            word-break: break-all !important; /* Sécurité si vraiment trop long */
        }

        /* Réduction des icônes pour libérer de la largeur */
        .log-entry i {
            font-size: 0.7rem !important;
        }

        /* Petits ajustements des cellules gauche et droite */
        .log-cell-num { 
            font-size: 0.6rem !important; 
            border-right: 1px solid #ddd !important;
        }
        .log-cell-right { 
            font-size: 0.5rem !important; 
            border-left: 1px solid #ddd !important;
        }

        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    }

    /* MODAL UTM GENERATOR */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(42, 34, 26, 0.7);
        z-index: 2000;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(4px);
    }
    .modal-content {
        background: white;
        padding: 30px;
        border-radius: 12px;
        width: 90%;
        max-width: 500px;
        border: 1px solid var(--sable);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        border-bottom: 1px solid var(--vanille);
        padding-bottom: 10px;
    }
    .utm-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin: 20px 0;
    }
    .utm-btn {
        padding: 15px;
        border: 1px solid var(--sable);
        background: var(--fond);
        border-radius: 8px;
        cursor: pointer;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 0.7rem;
        text-transform: uppercase;
        transition: all 0.2s;
    }
    .utm-btn:hover { background: var(--vanille); border-color: var(--coco); transform: translateY(-2px); }
    .utm-custom-box {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px dashed var(--sable);
    }
    .utm-input {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--sable);
        border-radius: 6px;
        margin-bottom: 10px;
        font-weight: bold;
        text-transform: uppercase;
        text-align: center;
    }

    /* Transition pour éviter les sauts et animer les changements d'état */
    .utm-input, .utm-btn, .btn-add {
        transition: all 0.3s ease !important;
    }
    .success-state {
        border-color: var(--vert) !important;
        color: var(--vert) !important;
    }
    .btn-success-state {
        background-color: var(--vert) !important;
        border-color: var(--vert) !important;
        color: white !important;
    }
</style>
</head>
<body>
    <div class="dashboard-container">
        <AdminHeader currentPage="stats" title="Dashboard" />

        <div class="actions-bar">
            <button onclick="openUtmModal()" class="btn btn-add" style="background: var(--color-ios);">
                <i class="fa-solid fa-link"></i> GÉNÉRATEUR DE LIENS
            </button>
            <button onclick="window.print()" class="btn btn-add">
                <i class="fa-solid fa-file-pdf"></i> RAPPORT
            </button>
            <button onclick="exportLogsToCSV()" class="btn btn-add">
                <i class="fa-solid fa-file-export"></i> EXPORT
            </button>
        </div>

        <div class="stats-row">
            <div class="stat-card-mini card-total"><span class="val">{totalVisitesHumaines}</span><span class="label">Visites</span></div>
            <div class="stat-card-mini card-qr"><span class="val">{qrCount}</span><span class="label">Scans QR</span></div>
            <div class="stat-card-mini card-ios"><span class="val">{iosCount}</span><span class="label">Apple</span></div>
            <div class="stat-card-mini card-android"><span class="val">{androidCount}</span><span class="label">Android</span></div>
            <div class="stat-card-mini card-pc"><span class="val">{pcCount}</span><span class="label">Ordinateur</span></div>
