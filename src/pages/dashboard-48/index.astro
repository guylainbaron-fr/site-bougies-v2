                <span id="live-clock" style="font-size: 1.1rem; font-weight: 800; font-family: monospace;">00:00:00</span>
                <span id="live-date" style="font-size: 0.5rem; text-transform: uppercase; font-weight:bold;">...</span>
            </div>
        </div>

<div class="dist-section">
    <div class="dist-header">Technologie</div>
    <div class="distribution-bar">
        {iosCount > 0 && <div class="segment bg-ios" style={`width: ${iosPct}%`}>{iosPct > 10 ? `${iosPct}%` : ''}</div>}
        {androidCount > 0 && <div class="segment bg-android" style={`width: ${androidPct}%`}>{androidPct > 10 ? `${androidPct}%` : ''}</div>}
        {pcCount > 0 && <div class="segment bg-pc" style={`width: ${pcPct}%`}>{pcPct > 10 ? `${pcPct}%` : ''}</div>}
        {botCount > 0 && <div class="segment" style={`width: ${botPct}%; background-color: var(--violet);`}>{botPct > 10 ? `${botPct}%` : ''}</div>}
    </div>
    <div class="bar-legend">
        <span class="legend-item"><span class="dot bg-ios"></span> Apple ({iosPct}%)</span>
        <span class="legend-item"><span class="dot bg-android"></span> Android ({androidPct}%)</span>
        <span class="legend-item"><span class="dot bg-pc"></span> Ordinateur ({pcPct}%)</span>
        <span class="legend-item"><span class="dot" style="background-color: #9b59b6;"></span> Robots ({botPct}%)</span>
    </div>
</div>

<div class="dist-section">
    <div class="dist-header">Origine</div>
    <div class="distribution-bar">
        {qrCount > 0 && <div class="segment bg-qr" style={`width: ${qrPct}%`}>{qrPct > 10 ? `${qrPct}%` : ''}</div>}
        {directPct > 0 && <div class="segment bg-direct" style={`width: ${directPct}%`}>{directPct > 10 ? `${directPct}%` : ''}</div>}
    </div>
    <div class="bar-legend">
        <span class="legend-item"><span class="dot bg-qr"></span> Scan QR ({qrPct}%)</span>
        <span class="legend-item"><span class="dot bg-direct"></span> Lien Web ({directPct}%)</span>
    </div>
</div>

        <div class="actions-row">

    <div style="margin-right: auto; display:flex; align-items:center; gap:12px; border-right: 1px solid var(--sable); padding-right: 20px;">
        <div style="display:flex; align-items:center; gap:8px;">
            <input type="text" id="confirmBots" placeholder="ROBOTS" style="width:80px; padding:8px; border:1px solid var(--violet); border-radius:4px; font-size:0.7rem; text-align:center; font-weight:bold; color: var(--violet);" />
            <form method="POST" style="margin:0;">
                <input type="hidden" name="action" value="clean_bots" />
                <button type="submit" id="botsBtn" disabled style="background: var(--violet); color: white; opacity:0.5; border:none; padding:8px 12px; border-radius:4px; font-size:0.6rem; font-weight:bold; cursor:not-allowed;">NETTOYER</button>
            </form>
        </div>
        
        <div style="display: flex; flex-direction: column;">
            <span style="font-size: 0.5rem; text-transform: uppercase; font-weight: 800; opacity: 0.5; letter-spacing: 0.5px; color: var(--violet);">Dernier Ménage</span>
            <span style="font-size: 0.65rem; font-weight: 700; color: var(--violet);">{lastCleanBotsDate}</span>
        </div>
