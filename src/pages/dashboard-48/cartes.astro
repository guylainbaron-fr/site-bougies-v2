---
// src/pages/dashboard-48/cartes.astro
import ThankYouCard from '../../components/ThankYouCard.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import '../../styles/admin.css';
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="robots" content="noindex, nofollow">
    <title>Impression Cartes | Atelier</title>
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta name="theme-color" content="#fdfaf7">
    <style>
        .preview-container {
            flex-grow: 1; 
            display: flex;
            justify-content: center; 
            padding: 40px 0;
            overflow-x: auto;
            background: var(--fond-ecume);
        }

        .page-a4 {
            width: 210mm; 
            height: 297mm; 
            background: white; 
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transform: scale(0.6);
            transform-origin: top center;
            margin-bottom: -100mm;
        }

        .half {
          flex: 1;
          display: flex;
          justify-content: center;
          align-items: center;
          position: relative;
      }

      .cut-line {
          position: absolute;
          bottom: 0; left: 0; right: 0;
          border-bottom: 1px dashed #eee;
      }

      /* FOOTER HARMONISÉ */
      .dashboard-footer {
          margin-top: 30px;
          padding: 20px 0;
          border-top: 1px solid var(--sable-dore);
          text-align: center;
      }

      .dashboard-footer p {
          margin: 0;
          font-size: 0.6rem;
          text-transform: uppercase;
          letter-spacing: 2px;
          font-weight: 800;
          color: var(--brun-coco);
          opacity: 0.6;
      }

      /* --- MÉTHODE IMPRESSION --- */
      @media print {
          @page { size: A4 portrait; margin: 0 !important; }
          body { padding: 0; background: white; }
          .admin-header, .dashboard-footer, .actions-bar { display: none !important; }
          .dashboard-container { max-width: none; margin: 0; }
          .preview-container { padding: 0; overflow: hidden; display: block; }
          .page-a4 { transform: none !important; box-shadow: none !important; margin: 0 !important; width: 210mm !important; height: 297mm !important; }
      }
    </style>
  </head>
  <body>
    <div class="dashboard-container">
        <AdminHeader currentPage="cartes" title="Impression Cartes" />

        <div class="actions-bar">
            <button class="btn btn-add" onclick="window.print()">
                <i class="fa-solid fa-print"></i> Imprimer les cartes
            </button>
        </div>

        <div class="preview-container">
            <div class="page-a4">
              <div class="half">
                <ThankYouCard />
                <div class="cut-line"></div> 
              </div>
              <div class="half">
                <ThankYouCard />
              </div>
            </div>
        </div>

        <footer class="dashboard-footer">
            <p>&copy; {currentYear} Jean François & Aniuta — Dashboard Atelier</p>
        </footer>
    </div>
  </body>
</html>