---
// 1. Génération de l'année
const currentYear = new Date().getFullYear();

// 2. Import des styles et polices (Comme dans MainLayout)
import '../styles/style.css';
import '../styles/fa/css/brands.min.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';

// 3. Import des images pour les favicons (Ajuste les chemins si besoin)
import faviconSvg from '../assets/images/favicon.svg';
import favicon32 from '../assets/images/favicon_32x32.png';
import favicon16 from '../assets/images/favicon_16x16.png';
---
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    
    <meta name="google-site-verification" content="googleca94fc0ed3c52975" />

    <title>Page perdue | Jean François & ANIUTA</title>
    
    {/* ON A SUPPRIMÉ LE LIEN GOOGLE FONTS ICI - L'IMPORT JS S'EN OCCUPE */}

    <link rel="icon" type="image/svg+xml" href={faviconSvg.src}>
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32.src}>
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16.src}>
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="manifest" href="/manifest.json">

    <style>
        /* --- RESET & BASE --- */
        * { margin: 0; padding: 0; box-sizing: border-box; text-decoration: none; }
        :root { --marron-artisan: #3d2b1f; --or-doux: #b8860b; --or-brillant: #d4af37; }
        
        html, body { 
            min-height: 100vh;
            min-height: 100dvh; 
            background-color: #fdfaf7; 
            color: var(--marron-artisan); 
            font-family: 'Poppins', sans-serif; 
        }

        body { 
            display: flex; 
            flex-direction: column;
            overflow-x: hidden;
            overflow-y: auto; 
        }

        @media (min-width: 1025px) {
            body { height: 100vh; overflow-y: hidden; }
        }

        /* --- BANDEAU DE NOËL --- */
        .holiday-bar {
            background-color: #fdfaf7;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            padding: 8px 10px;
            width: 100%;
            border-bottom: 1px solid rgba(61, 43, 31, 0.1);
            z-index: 1000;
            flex-shrink: 0;
        }

        .holiday-text {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-align: center;
            background: linear-gradient(to right, #3d2b1f 20%, var(--or-doux) 50%, #3d2b1f 80%);
            background-size: 200% auto;
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine-right 6s linear infinite;
        }

        .snow-group { display: flex; gap: 8px; opacity: 0.7; }
        .snowflake-css {
            width: 1px; height: 10px; background: var(--marron-artisan); 
            position: relative;
            animation: rotate-snow 10s infinite linear, twinkle 3s infinite ease-in-out;
        }
        .snowflake-css:nth-child(2) { animation-delay: 0.5s, 1.2s; animation-duration: 10s, 4.5s; }
        .snowflake-css:nth-child(3) { animation-delay: 1s, 0.2s; animation-duration: 10s, 2.5s; }
        .snowflake-css::before, .snowflake-css::after {
            content: ""; position: absolute; width: 1px; height: 10px; background: inherit; top: 0; left: 0;
        }
        .snowflake-css::before { transform: rotate(60deg); }
        .snowflake-css::after { transform: rotate(120deg); }

        /* --- LE GRAND FLOCON --- */
        .snowflake-artisan {
            position: relative; 
            width: clamp(160px, 22vh, 220px); 
            height: clamp(160px, 22vh, 220px);
            margin: 0 auto 15px; 
            display: flex; justify-content: center; align-items: center;
            animation: rotate-snow 30s infinite linear;
            cursor: pointer; transition: 0.5s ease;
            flex-shrink: 0;
        }
        .snowflake-artisan:hover {
            animation: rotate-snow 8s infinite linear;
            filter: drop-shadow(0 0 20px var(--or-brillant));
        }
        .axis {
            position: absolute; width: 10px; height: 50%; 
            background: var(--marron-artisan); border-radius: 5px;
            transform-origin: bottom center; bottom: 50%;
        }
        .snowflake-artisan:hover .axis, 
        .snowflake-artisan:hover .chevron::before, 
        .snowflake-artisan:hover .chevron::after {
            background: var(--or-doux);
        }
        .axis:nth-child(1) { transform: rotate(0deg); }
        .axis:nth-child(2) { transform: rotate(60deg); }
        .axis:nth-child(3) { transform: rotate(120deg); }
        .axis:nth-child(4) { transform: rotate(180deg); }
        .axis:nth-child(5) { transform: rotate(240deg); }
        .axis:nth-child(6) { transform: rotate(300deg); }
        .chevron { position: absolute; width: 100%; height: 30px; left: 0; }
        .chevron.top { top: 0px; }
        .chevron.bottom { top: 42%; }
        .chevron::before, .chevron::after {
            content: ""; position: absolute; width: 10px; height: 22px; 
            background: var(--marron-artisan); border-radius: 5px;
        }
        .chevron::before { transform: rotate(-45deg); left: -10px; }
        .chevron::after { transform: rotate(45deg); right: -10px; }

        /* --- CONTENU --- */
        main { 
            flex: 1; display: flex; flex-direction: column; 
            justify-content: center; align-items: center; 
            text-align: center; padding: 20px;
        }
        h1 { 
            font-size: clamp(4rem, 13vh, 7rem); color: var(--or-doux); 
            position: relative; line-height: 0.7; font-weight: 800; 
        }
        h1::after {
            content: "404"; position: absolute; top: 0; left: 50%;
            transform: translateX(-50%); color: var(--marron-artisan); 
            clip-path: inset(50% 0 0 0);
        }
        h2 { font-size: 1.5rem; margin: 20px 0 10px; font-weight: 700; text-transform: uppercase; }
        p { max-width: 500px; color: #666; margin-bottom: 25px; line-height: 1.4; font-size: 0.95rem; }

        .btn-retour { 
            padding: 15px 40px; background-color: var(--marron-artisan); 
            color: white !important; border-radius: 50px; 
            font-weight: 600; transition: 0.3s;
            box-shadow: 0 4px 15px rgba(61, 43, 31, 0.2);
        }
        .btn-retour:hover { transform: scale(1.05); background: var(--or-doux); }

        /* --- FOOTER MODIFIÉ --- */
        footer { padding: 20px 0 40px; text-align: center; flex-shrink: 0; }
        .social-links a { 
            margin: 0 10px; color: var(--marron-artisan) !important; font-size: 1.2rem;
            display: inline-flex; align-items: center; justify-content: center;
            width: 44px; height: 44px; border: 1px solid rgba(61, 43, 31, 0.1); 
            border-radius: 50%; transition: 0.4s;
            background-color: transparent;
        }
        
        .social-links a:hover { 
            background-color: var(--or-doux) !important;
            color: #fff !important; 
            border-color: var(--or-doux); 
            transform: translateY(-5px); 
        }

        /* --- ANIMATIONS --- */
        @keyframes rotate-snow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes shine-right { 0% { background-position: 200% center; } 100% { background-position: -200% center; } }
        @keyframes twinkle {
            0%, 100% { opacity: 0.2; transform: scale(0.8); }
            50% { opacity: 1; transform: scale(1.1); }
        }

        @media (max-width: 768px) {
            .holiday-text { font-size: 0.65rem; max-width: 65%; }
            .snowflake-css:nth-child(2), .snowflake-css:nth-child(3) { display: none; }
            main { justify-content: flex-start; padding-top: 50px; }
        }
    </style>
</head>
<body>

<div class="holiday-bar" role="complementary" aria-label="Vœux de la Nouvelle Année 2026">
    <div class="snow-group">
        <div class="snowflake-css"></div><div class="snowflake-css"></div><div class="snowflake-css"></div>
    </div>
    <span class="holiday-text">
        <strong>2026 s'éveille :</strong> même sous le givre, la flamme de la création reste vive.
    </span>
    <div class="snow-group">
        <div class="snowflake-css"></div><div class="snowflake-css"></div><div class="snowflake-css"></div>
    </div>
</div>

<main>
    <div class="snowflake-artisan">
        <div class="axis"><div class="chevron top"></div><div class="chevron bottom"></div></div>
        <div class="axis"><div class="chevron top"></div><div class="chevron bottom"></div></div>
        <div class="axis"><div class="chevron top"></div><div class="chevron bottom"></div></div>
        <div class="axis"><div class="chevron top"></div><div class="chevron bottom"></div></div>
        <div class="axis"><div class="chevron top"></div><div class="chevron bottom"></div></div>
        <div class="axis"><div class="chevron top"></div><div class="chevron bottom"></div></div>
    </div>
    <h1>404</h1>
    <h2>La piste est effacée...</h2>
    <p>Le blizzard a recouvert le chemin vers cette page. Ne restez pas dans la tempête, retrouvez la chaleur de notre atelier à l'accueil.</p>
    <a href="/" class="btn-retour">Retrouver la chaleur (Accueil)</a>
</main>

<footer>
    <div class="social-links">
        <a href="https://www.facebook.com/profile.php?id=61550190415219&locale=fr_FR" target="_blank"><i class="fab fa-facebook-f"></i></a>
        <a href="https://www.instagram.com/jean_francois_aniuta/" target="_blank"><i class="fab fa-instagram"></i></a>
        <a href="https://wa.me/33658909835" target="_blank"><i class="fab fa-whatsapp"></i></a>
        <a href="https://www.tiktok.com/@jeanfrancoisbaron2" target="_blank"><i class="fab fa-tiktok"></i></a>
        <a href="https://maps.app.goo.gl/TY3NhqRHVrUwbWwp6" target="_blank" aria-label="Voir l'atelier sur Google Maps"><i class="fab fa-google"></i></a>
    </div>
    <span style="color:#888; font-size: 0.75rem; display: block; margin-top: 15px;">
        © <span>{currentYear}</span> Jean François & Aniuta. Gravé dans la cire, protégé par l'hiver.
        | <a href="/mentions-legales" style="color:#777; text-decoration: underline; text-underline-offset: 3px; font-weight: 500;" title="Consulter les Mentions Légales et Conditions Générales de Vente">Mentions Légales & CGV</a>
    </span>
</footer>

</body>
</html>