---
import MainLayout from '../layouts/MainLayout.astro';
const pageId = "avis";

import { Image } from 'astro:assets';
import avisHeroImg from "../assets/images/avis-Img.webp";
---

<MainLayout 
  title="Livre d'Or : Avis sur nos Bougies & Sculptures | JF & A"
  description="Découvrez les témoignages de nos clients. Le réalisme de nos bougies cèpes et la qualité de nos sculptures bois font la fierté de l'artisanat lozérien."
  pageId={pageId}
>
<script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://jf-aniuta.vercel.app/#organization",
      "name": "Jean-François & Aniuta",
      "url": "https://jf-aniuta.vercel.app/",
      "logo": {
        "@type": "ImageObject",
        "@id": "https://jf-aniuta.vercel.app/#logo",
        "url": "https://jf-aniuta.vercel.app/images/logo_512.png",
        "contentUrl": "https://jf-aniuta.vercel.app/images/logo_512.png",
        "width": 512,
        "height": 512
      }
    },
    {
      "@type": "WebPage",
      "@id": "https://jf-aniuta.vercel.app/avis/#webpage",
      "url": "https://jf-aniuta.vercel.app/avis",
      "name": "Livre d'Or et Avis Clients | Jean-François & Aniuta",
      "description": "Découvrez les témoignages et avis sur nos sculptures en bois et bougies champignons ultra-réalistes.",
      "isPartOf": { "@id": "https://jf-aniuta.vercel.app/#website" },
      "about": { "@id": "https://jf-aniuta.vercel.app/#organization" }
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://jf-aniuta.vercel.app/#localbusiness",
      "name": "Jean-François & Aniuta",
      "image": "https://jf-aniuta.vercel.app/images/logo_512.png",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "reviewCount": "12" 
      },
      "parentOrganization": { "@id": "https://jf-aniuta.vercel.app/#organization" }
    }
  ]
}
</script>

    <section id="apropos-livre">
        <div class="container">
            <h2>L'Artisanat au Cœur de vos Foyers</h2>
            <div class="intro-avis-text">
                <p>
                    Chaque <strong>sculpture sur bois</strong> et chaque <strong>bougie champignon</strong> qui sort de notre atelier de Chasseradès est le fruit d'un travail passionné. Pour un atelier artisanal ancré en Lozère, <span class="highlight-atelier">votre confiance est notre plus belle récompense</span>.
                </p>
                <p>
                    Que vous ayez craqué pour le <strong>réalisme d'un cèpe</strong>, la finesse d'une <strong>bougie morille</strong> ou la douceur de notre vanille gourmande, vos retours nous aident à faire rayonner le savoir-faire lozérien. <strong>Merci de faire vivre l'artisanat français.</strong>
                </p>
            </div>
        </div>
    </section>

<section id="hero-signature-sculpture">
    <div class="container"> 
        <div class="avis-hero-header">
            <div class="etiquette-luxe">Livre d'Or</div>
            
            <div class="cepes-container">
                <Image 
                    src={avisHeroImg} 
                    alt="Sculpture de branche en bois et cèpes - Artisanat Lozère" 
                    class="img-cepes-hero" 
                    width={1032} 
                    height={490}
                    widths={[516, 1032]} 
                    sizes="(max-width: 768px) 516px, 1032px" 
                    loading="eager" 
                    fetchpriority="high"
                    decoding="async"
                />
            </div>
        </div>
    </div>
</section>

    <section id="avis-google-unique">
        <div class="container">
            <div class="google-modern-title">Témoignages & Expériences Clients</div>

            <div class="grille-google">
                <article class="carte-google-avis">
                    <div>
                        <div class="google-stars">★★★★★</div>
                        <p class="google-avis-texte">"Produits de qualités. Que ce soit les bougies parfumées ou bien les coffrets pour Noël c'est super bien réalisé. Les produits sont de qualités !"</p>
                    </div>
                    <span class="google-avis-auteur">— Paco Zapata</span>
                </article>

                <article class="carte-google-avis">
                    <div>
                        <div class="google-stars">★★★★★</div>
                        <p class="google-avis-texte">"Bougies et coffrets au top, vraiment très qualitatif !"</p>
                    </div>
                    <span class="google-avis-auteur">— MECS Le sentier</span>
                </article>

                <article class="carte-google-avis">
                    <div>
                        <div class="google-stars">★★★★★</div>
                        <p class="google-avis-texte">"Bougies magnifiques et originales ! les cèpes sont d'un réalisme incroyable et apportent une vraie touche chaleureuse à la deco."</p>
                    </div>
                    <span class="google-avis-auteur">— sandra gaugain</span>
                </article>

                <article class="carte-google-avis">
                    <div>
                        <div class="google-stars">★★★★★</div>
                        <p class="google-avis-texte">"De très belles réalisations, produits de qualités personne très agréable et à l'écoute lorsque j'ai passé ma commande , la livraison est rapide."</p>
                    </div>
                    <span class="google-avis-auteur">— billy chevet</span>
                </article>

                <article class="carte-google-avis">
                    <div>
                        <div class="google-stars">★★★★★</div>
                        <p class="google-avis-texte">"Je recommande vivement !!! Les produits sont de bonne qualité et sont très réalistes. Le thème correspond complètement à notre région !! Je félicite et remercie Jean François et Aniuta pour leur travail d’exception !!! Bravo à vous 😉 …"</p>
                    </div>
                    <span class="google-avis-auteur">— lionel de ranieri</span>
                </article>

                <article class="carte-google-avis placeholder-avis">
                    <div>
                        <div class="google-stars">★★★★★</div>
                        <p class="google-action-titre">Et vous ?</p>
                        <p class="google-avis-texte">Votre avis est précieux pour faire connaître nos créations en Lozère.</p>
                    </div>
                </article>
            </div>

            <div class="google-btn-wrapper">
                <a href="https://g.page/r/Ccq2wwBX0aHgEBM/review" target="_blank" rel="noopener noreferrer" class="google-btn-red">
                    <i class="fab fa-google"></i> Laisser un avis sur Google
                </a>
            </div>
            
            <div class="cta-wrapper">
                <div class="etiquette-signature">
                    <h3>L'Empreinte de votre Confiance</h3>
                    <p>
                        Un artisan ne crée rien sans un regard pour l'apprécier. Du <strong>bois sculpté</strong> à la <strong>cire coulée</strong>, notre travail ne s'achève réellement que lorsque nos créations s'éclairent chez vous. Votre satisfaction est bien plus qu'un avis : c'est la <strong>signature finale</strong> de notre passion.
                    </p>
                </div>
            </div>
        </div>
    </section>
</MainLayout>