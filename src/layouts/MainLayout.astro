---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/style.css';
import '../styles/fa/css/brands.min.css';

// IMPORT DES POLICES EN LOCAL
import '@fontsource/poppins/300.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';

import { getImage } from "astro:assets";
import heroHome from '../assets/images/hero-home.webp';

import faviconSvg from '../assets/images/favicon.svg';
import favicon32 from '../assets/images/favicon_32x32.png';
import favicon16 from '../assets/images/favicon_16x16.png';
import appleTouchIcon from '../assets/images/logo_512x512_white.png';

const { title, description, holidayMessage } = Astro.props;

// 1. GENERER L'URL CANONIQUE DYNAMIQUE
// Cela prend l'URL actuelle (ex: /bougies) et l'ajoute au domaine
const canonicalURL = new URL(Astro.url.pathname, "https://jf-aniuta.vercel.app");

const optimizedHero = await getImage({
  src: heroHome,
  width: 400,
  format: 'webp',
  quality: 80
});
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link 
      rel="preload" 
      as="image" 
      href={optimizedHero.src} 
      fetchpriority="high"
    />

    <meta property="og:locale" content="fr_FR">
    <meta property="og:title" content={title || "JF & A"}>
    <meta property="og:site_name" content="JF & A">
    <meta property="og:url" content={canonicalURL.href}>
    <meta property="og:type" content="website">
    <meta property="og:image" content={appleTouchIcon.src}>
    <meta property="og:description" content={description || "JF & A — Sculptures uniques sur bois local et bougies naturelles parfumées."}>
    
    <meta name="google-site-verification" content="googleca94fc0ed3c52975" />

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title || "JF & A"}>
    <meta name="twitter:description" content={description || "JF & A — Sculptures uniques sur bois local et bougies naturelles parfumées."}>
    <meta name="twitter:image" content={appleTouchIcon.src}>

    <title>{title}</title>
    <meta name="description" content={description}>
    
    <link rel="canonical" href={canonicalURL.href} />

    <link rel="icon" type="image/svg+xml" href={faviconSvg.src}>
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32.src}>
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16.src}>
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href={appleTouchIcon.src}>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#fdfaf7">

    <slot name="head" />
</head>
<body>
    <Header holidayMessage={holidayMessage} />
    
    <main>
        <slot /> 
    </main>

    <Footer />

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .catch(err => console.log('Erreur SW:', err));
            });
        }
    </script>
</body>
</html>